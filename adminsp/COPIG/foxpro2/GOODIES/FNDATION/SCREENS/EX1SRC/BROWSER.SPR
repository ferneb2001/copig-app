	PICTURE "@^ =;<>;<;>;<=;>=;==;IN" ;
	SIZE 3,6 ;
	DEFAULT "=" ;
	COLOR SCHEME 5, 6
@ 14,24 EDIT sought ;
	PICTURE "@K" ;
	SIZE 1,22,238 ;
	DEFAULT " " ;
	VALID _px10skox3()
@ 14,48 GET ad ;
	PICTURE "@*VN Add" ;
	SIZE 1,8,1 ;
	DEFAULT 1 ;
	VALID _px10skp6a()
@ 3,1 GET qp ;
	PICTURE "@&N" ;
	FROM query ;
	SIZE 8,56 ;
	DEFAULT 1 ;
	VALID _px10skpvd() ;
	DISABLE ;
	COLOR SCHEME 6
@ 11,4 GET bact ;
	PICTURE "@*HN Delete;;;Group" ;
	SIZE 1,9,4 ;
	DEFAULT 1 ;
	VALID _px10skq4q() ;
	DISABLE
@ 0,45 GET tg ;
	PICTURE "@^" ;
	FROM tags ;
	SIZE 3,12 ;
	DEFAULT 1 ;
	VALID _px10skqkc() ;
	COLOR SCHEME 5, 6
@ 18,11 GET qy ;
