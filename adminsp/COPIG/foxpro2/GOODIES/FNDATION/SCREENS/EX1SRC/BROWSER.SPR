*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║                  BROWSER Cleanup Code                   ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*

#REGION 1
*!*****************************************************************
*!
*!      Procedure: SETACTION
*!
*!*****************************************************************
PROCEDURE setaction
IF qptr = 0 OR qp > qptr
   SHOW GET bact DISABLE
   IF qp = qptr + 1 AND qptr<>0
      SHOW GET bact,4 ENABLE
   ENDIF
   SHOW GETS
   RETURN
ENDIF
SHOW GET bact,1 ENABLE
IF qptr = 1 OR qp = 1
   SHOW GET bact,2 DISABLE
ELSE
   SHOW GET bact,2 ENABLE
ENDIF
IF qptr = 1 OR qptr = qp
   SHOW GET bact,3 DISABLE
ELSE
   SHOW GET bact,3 ENABLE
ENDIF

*!*****************************************************************
*!
*!      Procedure: QRESET
*!
*!*****************************************************************
PROCEDURE qreset
QUERY = " "
qptr = 0
qp = 1
op = "="
sought = ""
DO setaction
SHOW GET sought

*!*****************************************************************
*!
*!      Procedure: FSET
*!
*!*****************************************************************
PROCEDURE fset
PRIVATE X, typ
IF QUERY(qp) = "═"
   SHOW GET fieldname DISABLE
   SHOW GET sought DISABLE
   SHOW GET op DISABLE
ELSE
   SHOW GET fieldname ENABLE
   X = notag(fieldname)
   typ = TYPE("&x")
   IF typ = "L"
      SHOW GET op DISABLE
      SHOW GET sought DISABLE
   ELSE
      SHOW GET op ENABLE
      SHOW GET sought ENABLE
   ENDIF
ENDIF
RETURN .T.

*!*****************************************************************
*!
*!      Procedure: QSET
*!
*!*****************************************************************
PROCEDURE qset
PRIVATE X, i
IF 0 < qp AND qp <= qptr
   X = QUERY(qp)
   IF X = "═"
      RETURN
   ENDIF
   i = AT(" ",X)
   IF i <= 1
      op = "="
      sought = ""
      fieldname = ontag(X)
   ELSE
      fieldname = SUBSTR(X,1,i-1)
      fieldname = ontag(fieldname)
      X = SUBSTR(X,i+1)
      i = AT(" ",X)
      op = SUBSTR(X,1,i-1)
      sought = nobrack(SUBSTR(X,i+1))
   ENDIF
   SHOW GET fieldname
   SHOW GET op
   SHOW GET sought
ENDIF

*!*****************************************************************
*!
*!      Procedure: NOBRACK
*!
*!*****************************************************************
FUNCTION nobrack
PARAMETER X
PRIVATE i,y,C
y = ""
FOR i = 1 TO LEN(X)
   C = SUBSTR(X,i,1)
   IF NOT C$"'{}"
      y = y + C
   ENDIF
ENDFOR
RETURN y


*!*****************************************************************
*!
*!      Procedure: SETTAGS
*!
*!*****************************************************************
PROCEDURE settags
DIMENSION flds(256), tags(256)
tags(1) = "Record#"
FOR i = 2 TO 256
   IF LEN(TAG(i-1)) = 0
      i = i - 1
      DIMENSION tags(i)
      EXIT
   ELSE
      tags(i) = TAG(i-1)
   ENDIF
ENDFOR

FOR fl = 1 TO 256
   IF LEN(FIELD(fl)) = 0
      fl = fl - 1
      DIMENSION flds(fl)
      EXIT
   ELSE
      flds(fl) = ontag(FIELD(fl))
   ENDIF
ENDFOR
fieldname = flds(1)
SHOW GET fieldname
SHOW GET tg

*!*****************************************************************
*!
*!      Procedure: ONTAG
*!
*!*****************************************************************
FUNCTION ontag
PARAMETER X
X = IIF(ASCAN(tags,X)#0,"■"," ") + X
RETURN X

*!*****************************************************************
*!
*!      Procedure: NOTAG
*!
*!*****************************************************************
FUNCTION notag
PARAMETER X
X = SUBSTR(X,2)
RETURN X

*!*****************************************************************
*!
*!      Procedure: EDITQUERY
*!
*!*****************************************************************
FUNCTION editquery
PARAMETER X
PRIVATE VAR, op, i, orig, out, v
orig = X
i = AT(" ", X)
IF i = 0
   RETURN orig
ENDIF
VAR = SUBSTR(X,1,i-1)
X = SUBSTR(X,i+1)
i = AT(" ", X)
op = SUBSTR(X,1,i-1)
X = SUBSTR(X,i+1)
IF op <> "IN"
   RETURN orig
ENDIF
out = "("
DO WHILE LEN(X) > 0
   i = AT(",", X)
   IF i = 0
      v = X
      X = ""
   ELSE
      v = SUBSTR(X,1,i-1)
      X = IIF(i=LEN(X),"",SUBSTR(X,i+1))
   ENDIF
   IF RIGHT(out,1) <> "("
      out = out + " OR "
   ENDIF
   out = out + VAR + "=" + v
ENDDO
out = out + ")"
RETURN out


*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX10SKOX3           sought VALID                       ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         BROWSER,     Record Number:    6   ║
*       ║ Variable:            sought                             ║
*       ║ Called By:           VALID Clause                       ║
