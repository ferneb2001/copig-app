*       ║ Snippet Number:      1                                  ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px10skox3     &&  sought VALID
#REGION 1
IF "'"$sought
   WAIT WINDOW "Can't have single quote in value" NOWAIT
   RETURN 0
ENDIF



*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX10SKP6A           ad VALID                           ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         BROWSER,     Record Number:    7   ║
*       ║ Variable:            ad                                 ║
*       ║ Called By:           VALID Clause                       ║
*       ║ Object Type:         Push Button                        ║
*       ║ Snippet Number:      2                                  ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px10skp6a     &&  ad VALID
#REGION 1
PRIVATE X, y, z
IF qptr = 50
   ?? CHR(7)
   WAIT WINDOW "query list is full" NOWAIT
   RETURN 0
ENDIF
X = notag(TRIM(fieldname))
y = ALLTRIM(sought)
typ = TYPE("&x")
IF EMPTY(y) AND NOT typ = "L"
   ?? CHR(7)
   WAIT WINDOW "Missing value" NOWAIT
   RETURN 0
ENDIF
DO CASE
CASE typ = "C"
   y = brackets(y,"'","'")
CASE typ = "D"
   y = brackets(y,"{","}")
CASE typ = "N"
   IF AT('"',y)<>0
      WAIT WINDOW "Numeric field; Quotes are not allowed" NOWAIT
      RETURN 0
   ENDIF
   typ2 = TYPE("&y")
   IF typ2 <> "N"
      WAIT WINDOW "Numeric field; A number is expected" NOWAIT
      RETURN 0
   ENDIF
ENDCASE
IF typ = "L"
   z = X
ELSE
   z = X + " " + op + " " + y
ENDIF
IF 0 < qp AND qp <= qptr
   QUERY(qp) = z
ELSE
   qptr = qptr + 1
   QUERY(qptr) = z
ENDIF
qp = qptr+1

SHOW GET qp ENABLE
DO setaction
_CUROBJ = 1

*!*****************************************************************
*!
*!      Procedure: BRACKETS
*!
*!*****************************************************************
FUNCTION brackets
PARAMETER X, b1, b2
PRIVATE out, i, v
IF op <> "IN"
   RETURN b1 + X + b2
ENDIF
out = ""
DO WHILE LEN(X) > 0
   i = AT(",", X)
   IF i = 0
      v = X
      X = ""
   ELSE
      v = SUBSTR(X,1,i-1)
      X = IIF(i=LEN(X),"",SUBSTR(X,i+1))
   ENDIF
   IF LEN(out) > 0
      out = out + ","
   ENDIF
   out = out + b1 + v + b2
ENDDO
RETURN out


