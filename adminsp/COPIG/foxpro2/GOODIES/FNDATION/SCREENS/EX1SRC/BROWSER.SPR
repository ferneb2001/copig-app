IF NOT WEXIST("locate")
	DEFINE WINDOW locate ;
		FROM INT((SROW()-22)/2),INT((SCOL()-61)/2) ;
		TO INT((SROW()-22)/2)+21,INT((SCOL()-61)/2)+60 ;
		FLOAT ;
		NOCLOSE ;
		SHADOW ;
		DOUBLE ;
		COLOR SCHEME 5
ENDIF


*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║             BROWSER Setup Code - SECTION 2              ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*

#REGION 1
PRIVATE sought, seektype, bact, ;
   flds, fl, qptr, QUERY, op, qp, ;
   tags, tg, i, bact, qy, dbfs, dx, dbc, ;
   fieldname

SET EXACT OFF

DIMENSION flds(256), QUERY(50), tags(256), dbfs(25)

dbc = 0
FOR i = 1 TO 25
   IF LEN(DBF(i)) # 0
      dbc = dbc + 1
      dbfs(dbc) = ALIAS(i)
   ENDIF
ENDFOR

IF dbc = 0
   X = GETFILE("DBF","Pick database to BROWSE")
   IF LEN(X) = 0
      WAIT WINDOW "Cancelled" NOWAIT
      RETURN
   ELSE
      USE (X)
      dbc = 1
      dbfs(1) = ALIAS()
   ENDIF
ELSE
   IF LEN(FIELD(1)) = 0
      SELECT (dbfs(1))
   ENDIF
ENDIF
DIMENSION dbfs(dbc)
dx = ALIAS()
fieldname = ""
tg = ""
DO settags

QUERY = " "
qptr = 0
qp = 1
sought = ""
op = "="
DO fset


