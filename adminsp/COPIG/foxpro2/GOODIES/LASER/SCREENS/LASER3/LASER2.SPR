*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px211stla     &&  bact VALID
#REGION 3
REGIONAL X, i
DO CASE
CASE bact = 1
   = ADEL(QUERY,qp)
   QUERY(50) = " "
   qptr = qptr - 1
   qp = MIN(qp,qptr+1)
   DO qset
CASE bact = 2
   IF qp > 1 AND qp <= qptr
      X = QUERY(qp-1)
      QUERY(qp-1) = QUERY(qp)
      QUERY(qp) = X
      qp = qp - 1
   ENDIF
CASE bact = 3
   IF qp <  qptr
      X = QUERY(qp+1)
      QUERY(qp+1) = QUERY(qp)
      QUERY(qp) = X
      qp = qp + 1
   ENDIF
CASE bact = 4
   IF qp < qptr
      FOR i = qptr TO qp+1 STEP -1
         QUERY(i+1) = QUERY(i)
      ENDFOR
      QUERY(qp + 1) = REPLICATE("═",40)
      qp = qp + 2
   ELSE
      QUERY(qptr+1) = REPLICATE("═",40)
      qp = qptr + 2
   ENDIF
   qptr = qptr + 1
ENDCASE
DO setaction
SHOW GET qp


