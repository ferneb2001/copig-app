*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX211SRUG           act2 VALID                         ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         CONTROL1,     Record Number:    2  ║
*       ║ Variable:            act2                               ║
*       ║ Called By:           VALID Clause                       ║
*       ║ Object Type:         Push Button                        ║
*       ║ Snippet Number:      2                                  ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px211srug     &&  act2 VALID
#REGION 2
do case
case act2 = 1
	go top
case act2 = 2
	skip -1
	if bof()
		go top
	endif
case act2 = 3
	skip 1
	if eof()
		go bottom
	endif
case act2 = 4
	go bottom
case act2 = 5
	clear read
endcase
show gets
return 0

*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX211SSCH           sought VALID                       ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         BROWSER,     Record Number:    6   ║
*       ║ Variable:            sought                             ║
*       ║ Called By:           VALID Clause                       ║
*       ║ Object Type:         Field                              ║
*       ║ Snippet Number:      3                                  ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px211ssch     &&  sought VALID
#REGION 3
IF "'"$sought
   WAIT WINDOW "Can't have single quote in value" NOWAIT
   RETURN 0
ENDIF
RETURN .T.



*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX211SSKU           ad VALID                           ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         BROWSER,     Record Number:    7   ║
*       ║ Variable:            ad                                 ║
*       ║ Called By:           VALID Clause                       ║
*       ║ Object Type:         Push Button                        ║
*       ║ Snippet Number:      4                                  ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px211ssku     &&  ad VALID
#REGION 3
REGIONAL X, y, z
IF qptr = 50
   ?? CHR(7)
   WAIT WINDOW "Query list is full" NOWAIT
   RETURN 0
ENDIF
X = notag(TRIM(fieldnam))
y = ALLTRIM(sought)
typ = TYPE("&x")
IF EMPTY(y) AND NOT typ = "L"
   ?? CHR(7)
   WAIT WINDOW "Missing value" NOWAIT
   RETURN 0
ENDIF
DO CASE
CASE typ = "C" OR typ = "M"
   y = brackets(y,"'","'")
CASE typ = "D"
   y = brackets(y,"{","}")
ENDCASE
IF typ = "L"
   z = X
ELSE
   z = X + " " + op + " " + y
ENDIF
IF 0 < qp AND qp <= qptr
   QUERY(qp) = z
ELSE
   qptr = qptr + 1
   QUERY(qptr) = z
ENDIF
qp = qptr+1
SHOW GET qp ENABLE
DO setaction
_CUROBJ = 1
RETURN .T.

*!*****************************************************************
*!
*!      Procedure: BRACKETS
*!
*!*****************************************************************
FUNCTION brackets
PARAMETER X, b1, b2
PRIVATE out, i, v
IF op <> "IN"
   RETURN b1 + X + b2
ENDIF
out = ""
DO WHILE LEN(X) > 0
   i = AT(",", X)
   IF i = 0
      v = X
      X = ""
   ELSE
      v = SUBSTR(X,1,i-1)
      X = IIF(i=LEN(X),"",SUBSTR(X,i+1))
   ENDIF
   IF LEN(out) > 0
      out = out + ","
   ENDIF
   out = out + b1 + v + b2
ENDDO
RETURN out


