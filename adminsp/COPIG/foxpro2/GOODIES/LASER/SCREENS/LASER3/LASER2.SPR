*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX211SRRA           Read Level Show                    ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         Multiple Screens                   ║
*       ║ Called By:           READ Statement                     ║
*       ║ Snippet Number:      12                                 ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px211srra     && Read Level Show
PRIVATE currwind
STORE WOUTPUT() TO currwind
*
* Show Code from screen: LASER2
*
#REGION 1
ord = iif(len(order())=0,"Record#",order())

IF SYS(2016) = "_PX211SOP7" OR SYS(2016) = "*"
	ACTIVATE WINDOW _px211sop7 SAME
	@ 1,65 SAY recno() ;
		SIZE 1,4 ;
		PICTURE "9,999"
	@ 1,51 SAY iif(DELETED(),'Yes','No ') ;
		SIZE 1,4
ENDIF
*
* Show Code from screen: BROWSER
*
#REGION 3
tg = IIF(LEN(ORDER())=0,"Record#",ORDER())

IF NOT EMPTY(currwind)
	ACTIVATE WINDOW (currwind) SAME
ENDIF