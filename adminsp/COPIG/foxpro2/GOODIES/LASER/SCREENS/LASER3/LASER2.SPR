*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX211SUBG           qy VALID                           ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         BROWSER,     Record Number:   11   ║
*       ║ Variable:            qy                                 ║
*       ║ Called By:           VALID Clause                       ║
*       ║ Object Type:         Push Button                        ║
*       ║ Snippet Number:      8                                  ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px211subg     &&  qy VALID
#REGION 3
REGIONAL X, i, CNT, stime, etime, y, rno, K
IF qptr = 0
   WAIT WINDOW ALLTRIM(TRANS(RECCOUNT(),"9,999,999"))+" Records" NOWAIT
   ACTIVATE SCREEN
   BROWSE LAST
ELSE
   FOR K = 1 TO qptr
      IF QUERY(K) <> "═"
         X = "("+editquery(TRIM(QUERY(K)))
         EXIT
      ENDIF
   ENDFOR
   FOR i = K+1 TO qptr
      IF QUERY(i) = "═"
         IF QUERY(i-1) = "═"
            LOOP
         ENDIF
         IF i<>qptr
         	X = X + ") OR ("
         ENDIF
      ELSE
         IF QUERY(i-1) <> "═"
            X = X + " AND "
         ENDIF
         X = X + editquery(TRIM(QUERY(i)))
      ENDIF
   ENDFOR
   X = X + ")"
   rno = RECNO()
   stime = SECONDS()
   COUNT TO CNT FOR &x
   etime = SECONDS()
   y = ALLTRIM(TRANS(CNT,"9,999,999"))+" Records, "
   y = y + ALLTRIM(TRANS(etime-stime,"999.99")) + " Secs."
   WAIT WINDOW y NOWAIT
   IF CNT = 0
      GO rno
   ELSE
      GO TOP
      ACTIVATE SCREEN
      BROWSE LAST FOR &x
   ENDIF
ENDIF
_CUROBJ = 1
SHOW GETS





