#REGION 1
** this program creates a data entry screen for the laser database

*
*	Initialize the arrays
*
regional studs, rats, st, rt, ltags, saverow
dimension ltags(256)
select 	distinct studio;
		order by studio;
		from laser;
		into arra studs
		
select 	distinct rating;
		order by rating;
		from laser;
		into arra rats

do setltags
go top

store srow() to saverow
if ('VGA'$sys(2006) or 'EGA'$sys(2006)) and srow() < 26 and 'LASER3'$sys(16)
	set display to vga50
endif
if 'APP3'$sys(16) and !('VGA'$sys(2006) or 'EGA'$sys(2006))
	wait window 'This program works best in 50 line mode' nowait
endif
do menu.mpr



*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║             BROWSER Setup Code - SECTION 2              ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*

#REGION 3
REGIONAL sought, seektype, bact, ;
   flds, fl, qptr, QUERY, op, qp, ;
   tags, tg, i, bact, qy, dbfs, dx, dbc, ;
   fieldnam

DIMENSION flds(256), QUERY(50), tags(256), dbfs(25)

dbc = 0
FOR i = 1 TO 25
   IF LEN(DBF(i)) # 0
      dbc = dbc + 1
      dbfs(dbc) = ALIAS(i)
   ENDIF
ENDFOR

IF dbc = 0
   X = GETFILE("DBF","Pick database to BROWSE")
   IF LEN(X) = 0
      WAIT WINDOW "Cancelled" NOWAIT
      RETURN
   ELSE
      USE (X)
      dbc = 1
      dbfs(1) = ALIAS()
   ENDIF
ELSE
   IF LEN(FIELD(1)) = 0
      SELECT (dbfs(1))
   ENDIF
ENDIF
DIMENSION dbfs(dbc)
dx = ALIAS()
fieldnam = ""
tg = ""
DO settags

QUERY = " "
qptr = 0
qp = 1
sought = ""
op = "="
DO fset


