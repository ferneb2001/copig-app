*    

#REGION 1
IF WVISIBLE("_pwi100i4x")
	ACTIVATE WINDOW _pwi100i4x SAME
ELSE
	ACTIVATE WINDOW _pwi100i4x NOSHOW
ENDIF
@ 1,2 GET tagnum ;
	PICTURE "@^" ;
	FROM idxtags ;
	SIZE 3,14 ;
	DEFAULT 1 ;
	COLOR SCHEME 5, 6
@ 5,4 GET ordbut ;
	PICTURE "@*VT \!OK;\?Cancel" ;
	SIZE 1,10,1 ;
	DEFAULT 1
@ 0,3 SAY "Index order:"

IF NOT WVISIBLE("_pwi100i4x")
	ACTIVATE WINDOW _pwi100i4x
ENDIF

READ CYCLE ;
	DEACTIVATE _pwi100jhz()

RELEASE WINDOW _pwi100i4x
SELECT (m.currarea)


#REGION 0
IF m.talkstat = "ON"
	SET TALK ON
ENDIF
IF m.compstat = "ON"
	SET COMPATIBLE ON
ENDIF


