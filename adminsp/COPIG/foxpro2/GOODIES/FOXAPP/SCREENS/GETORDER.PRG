*    

#REGION 1

IF TYPE("tagnum") = "U"
   PUBLIC tagnum
   tagnum = 1
ENDIF
m.startord = ORDER()

SET ORDER TO 0
numtag = 1
DO WHILE "" <> TAG(numtag)
   numtag = numtag + 1
ENDDO

DIMENSION idxtags(numtag-1)
i = 1
DO WHILE i <= numtag-1
   idxtags[i] = TAG(i)
   i = i + 1
ENDDO
SET ORDER TO (m.startord)


