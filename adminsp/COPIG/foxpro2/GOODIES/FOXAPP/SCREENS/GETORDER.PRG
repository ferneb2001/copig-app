	DEFINE WINDOW _pwi100i4x ;
		FROM INT((SROW()-11)/2),INT((SCOL()-20)/2) ;
		TO INT((SROW()-11)/2)+10,INT((SCOL()-20)/2)+19 ;
		FLOAT ;
		NOCLOSE ;
		SHADOW ;
		DOUBLE ;
		COLOR SCHEME 5
