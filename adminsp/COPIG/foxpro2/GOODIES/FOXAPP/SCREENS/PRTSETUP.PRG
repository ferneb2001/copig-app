*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║                  PRTSETUP Cleanup Code                  ║
*       ║                                                         ║ 
*       ╙─────────────────────────────────────────────────────────╜
*    

#REGION 1
DO CASE
CASE okbut = 1
   SET PRINTER TO

   IF prtstat = 1
      SET PRINT ON
   ELSE
      SET PRINT OFF
   ENDIF

   pdest = ALLTRIM(UPPER(pdest))
   DO CASE
   CASE pdest = 'FILE'
      IF !EMPTY(pfilname)
         SET PRINTER TO (pfilname)
      ELSE
         SET PRINTER TO
      ENDIF
   OTHERWISE
      pfilname = ''
      SET PRINTER TO &pdest
   ENDCASE
CASE cancbut = 1
   IF origprtstat = 1
      SET PRINT ON
   ELSE
      SET PRINT OFF
   ENDIF
   pdest = origdest
   pfilname = prt_infile
ENDCASE



