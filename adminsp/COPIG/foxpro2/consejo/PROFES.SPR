*

IF USED("spprof")
	SELECT spprof
	SET ORDER TO 0
ELSE
	SELECT 0
	USE (LOCFILE("spprof.dbf","DBF","Where is spprof?"));
		AGAIN ALIAS spprof ;
		ORDER 0
ENDIF


