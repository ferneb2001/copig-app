*       ║                                                         ║
*       ║ _PX90Z5EHT           m.for VALID                        ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         REPORTS,     Record Number:   15   ║
*       ║ Variable:            m.for                              ║
*       ║ Called By:           VALID Clause                       ║
*       ║ Object Type:         Check Box                          ║
*       ║ Snippet Number:      4                                  ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px90z5eht     &&  m.for VALID
#REGION 1
IF EMPTY(forexpr)
	GETEXPR "Enter FOR expression:" TO forexpr TYPE 'L'
ELSE
	GETEXPR "Enter FOR expression:" TO forexpr TYPE 'L' DEFAULT forexpr
ENDIF
	
m.for = IIF(EMPTY(forexpr), 0, 1)
SHOW GET m.for	


