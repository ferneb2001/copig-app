*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         REPORTS,     Record Number:    8   ║
*       ║ Variable:            m.report                           ║
*       ║ Called By:           VALID Clause                       ║
*       ║ Object Type:         List                               ║
*       ║ Snippet Number:      1                                  ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px90z5dzp     &&  m.report VALID
#REGION 1
repo = ALLTRIM(reps[m.report,1])+".FRX"
IF NOT FILE(repo)
	WAIT WINDOW "Report not found" NOWAIT
	RETURN
ENDIF
MODIFY REPORT &repo


*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX90Z5E4R           m.output VALID                     ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         REPORTS,     Record Number:    9   ║
*       ║ Variable:            m.output                           ║
*       ║ Called By:           VALID Clause                       ║
*       ║ Object Type:         Radio Button                       ║
*       ║ Snippet Number:      2                                  ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px90z5e4r     &&  m.output VALID
#REGION 1
PRIVATE m.reponame
IF m.report = 0
	WAIT WINDOW 'Please select a report' NOWAIT
	RETURN
ENDIF
m.reponame = ALLTRIM(reps[m.report,1])+".TXT"
IF m.output = "To File"
	m.filename = ALLTRIM(PUTFILE("Output file:", reponame,"TXT"))
	SHOW GET m.filename
ELSE
	m.filename = SPACE(20)
	SHOW GET m.filename
ENDIF


