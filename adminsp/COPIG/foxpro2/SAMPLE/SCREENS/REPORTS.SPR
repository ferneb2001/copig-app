#REGION 0
REGIONAL m.currarea, m.talkstat, m.compstat

IF SET("TALK") = "ON"
	SET TALK OFF
	m.talkstat = "ON"
ELSE
	m.talkstat = "OFF"
ENDIF
m.compstat = SET("COMPATIBLE")
SET COMPATIBLE FOXPLUS

*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║                    Window definitions                   ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*

IF NOT WEXIST("reports")
	DEFINE WINDOW reports ;
		FROM INT((SROW()-18)/2),INT((SCOL()-58)/2) ;
		TO INT((SROW()-18)/2)+17,INT((SCOL()-58)/2)+57 ;
		FLOAT ;
		NOCLOSE ;
		SHADOW ;
		DOUBLE ;
		COLOR SCHEME 5
ENDIF


*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║             REPORTS Setup Code - SECTION 2              ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*

#REGION 1
PRIVATE m.output, m.filename, m.choice, m.fromname, ;
	m.report, reps, m.savearea,	m.count, m.i, ;
	m.scope, m.record, forexpr, whileexpr, m.saverec, m.while, ;
	m.for, repo, options, to , m.plain, m.summary, m.noeject

m.choice   = ""
m.output   = "Preview"
m.filename = SPACE(20)
m.plain    = .F.
m.summary  = .F.
m.noeject  = .F.
m.report   = 1
m.savearea = SELECT()
m.saverec  = RECNO()

forexpr    = ""
whileexpr  = ""

IF NOT locatedb("reports",1)
	RELEASE WINDOW reports
	RETURN
ENDIF

COUNT FOR ALLTRIM(Modtype) = m.module TO m.count
IF EMPTY(m.count)
	WAIT WINDOW "No reports in this Module" NOWAIT
	USE
	SELECT (m.savearea)	
	RELEASE WINDOW reports
	RETURN
ENDIF

DIMENSION reps[m.count,2]
COPY TO ARRAY reps FIELDS ;
	Reportname, Contents ;
	FOR ALLTRIM(Modtype) = m.module
	
FOR i = 1 TO m.count
	reps[i,2] = " "+reps[i,1]+" .. "+reps[i,2]
	IF NOT FILE(reps[i,1]+".FRX")
		reps[i,2] = "\"+reps[i,2]
	ENDIF
ENDFOR

USE
SELECT (m.savearea)


*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║                  REPORTS Screen Layout                  ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*

#REGION 1
IF WVISIBLE("reports")
	ACTIVATE WINDOW reports SAME
ELSE
	ACTIVATE WINDOW reports NOSHOW
ENDIF
@ 0,1 TO 7,38
@ 8,1 TO 12,38
@ 0,39 TO 4,55
@ 0,21 SAY " Description "
@ 0,3 SAY " Report "
@ 8,39 TO 12,55
@ 1,2 GET m.report ;
	PICTURE "@&N" ;
	FROM reps ;
	RANGE 2 ;
	SIZE 6,36 ;
	DEFAULT 1 ;
	VALID _px90z5dzp() ;
	COLOR SCHEME 6
@ 9,3 GET m.output ;
	PICTURE "@*RVN Pre\<view;\<To File;To \<Print" ;
	SIZE 1,12,0 ;
	DEFAULT 1 ;
	VALID _px90z5e4r()
@ 10,16 EDIT m.filename ;
	PICTURE "@TK" ;
	SIZE 1,21,0 ;
	DEFAULT " " ;
	COLOR SCHEME 1
@ 1,41 GET m.plain ;
	PICTURE "@*C P\<lain" ;
	SIZE 1,9 ;
	DEFAULT 0
@ 2,41 GET m.summary ;
	PICTURE "@*C Summar\<y" ;
	SIZE 1,11 ;
	DEFAULT 0
@ 3,41 GET m.noeject ;
	PICTURE "@*C \<No Eject" ;
	SIZE 1,12 ;
	DEFAULT 0
@ 6,43 GET m.gethelp ;
	PICTURE "@*VN \<Help" ;
	SIZE 1,8,1 ;
	DEFAULT 1 ;
	VALID _px90z5ee8()
@ 9,41 GET m.for ;
	PICTURE "@*C \<For..." ;
	SIZE 1,10 ;
	DEFAULT 0 ;
	VALID _px90z5eht()
@ 11,41 GET m.while ;
	PICTURE "@*C \<While..." ;
	SIZE 1,12 ;
	DEFAULT 0 ;
	VALID _px90z5eni()
@ 14,10 GET m.choice ;
	PICTURE "@*HN \!\<OK;\<Modify;\?\<Cancel" ;
	SIZE 1,10,4 ;
	DEFAULT 1 ;
	VALID _px90z5es8()

IF NOT WVISIBLE("reports")
	ACTIVATE WINDOW reports
ENDIF

READ CYCLE ;
	WHEN _px90z5f6m()

RELEASE WINDOW reports

#REGION 0
IF m.talkstat = "ON"
	SET TALK ON
ENDIF
IF m.compstat = "ON"
	SET COMPATIBLE ON
ENDIF


