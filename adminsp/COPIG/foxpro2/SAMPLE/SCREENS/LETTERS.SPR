#REGION 0
REGIONAL m.currarea, m.talkstat, m.compstat

IF SET("TALK") = "ON"
	SET TALK OFF
	m.talkstat = "ON"
ELSE
	m.talkstat = "OFF"
ENDIF
m.compstat = SET("COMPATIBLE")
SET COMPATIBLE FOXPLUS

*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║                    Window definitions                   ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*

IF NOT WEXIST("letters")
	DEFINE WINDOW letters ;
		FROM INT((SROW()-16)/2),INT((SCOL()-56)/2) ;
		TO INT((SROW()-16)/2)+15,INT((SCOL()-56)/2)+55 ;
		FLOAT ;
		NOCLOSE ;
		SHADOW ;
		DOUBLE ;
		COLOR SCHEME 5
ENDIF


*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║             LETTERS Setup Code - SECTION 2              ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*

#REGION 1
PRIVATE m.choice, forexpr, whileexpr, m.savearea

m.savearea = SELECT()
m.choice   = ""
forexpr  = ""
whileexpr= ""

IF NOT locatedb("letters",1)
	RELEASE WINDOW letters
	RETURN
ENDIF

m.lett = Contents


#REGION 1
DEFINE POPUP _px90z5n6m ;
	PROMPT FIELD Contents ;
	SCROLL ;
	MARGIN ;
	MARK ""


*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║                  LETTERS Screen Layout                  ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*

#REGION 1
IF WVISIBLE("letters")
	ACTIVATE WINDOW letters SAME
ELSE
	ACTIVATE WINDOW letters NOSHOW
ENDIF
@ 0,1 TO 9,37
@ 0,3 SAY " Letter "
@ 10,1 TO 13,22
@ 10,23 TO 13,37
@ 1,3 GET m.lett ;
	PICTURE "@&N" ;
	POPUP _px90z5n6m ;
	SIZE 8,33 ;
	DEFAULT " " ;
	WHEN _px90z5nea() ;
	VALID _px90z5nin() ;
	COLOR SCHEME 6
@ 2,39 GET m.choice ;
	PICTURE "@*VN \!\<See Letter;\<Print;\?\<Cancel" ;
	SIZE 1,14,1 ;
	DEFAULT 1 ;
	VALID _px90z5nm9()
@ 11,3 GET m.prnscope ;
	PICTURE "@*RVN Cu\<rrent Record;\<All Records" ;
	SIZE 1,18,0 ;
	DEFAULT 1 ;
	VALID _px90z5nrq()
@ 11,25 GET m.for ;
	PICTURE "@*C \<For..." ;
	SIZE 1,10 ;
	DEFAULT 0 ;
	VALID _px90z5nz1() ;
	DISABLE
@ 12,25 GET m.while ;
	PICTURE "@*C \<While..." ;
	SIZE 1,12 ;
	DEFAULT 0 ;
	VALID _px90z5o4m() ;
	DISABLE
@ 11,42 GET m.gethelp ;
	PICTURE "@*VN \<Help" ;
	SIZE 1,8,1 ;
	DEFAULT 1 ;
	VALID _px90z5oa9()

IF NOT WVISIBLE("letters")
	ACTIVATE WINDOW letters
ENDIF

READ CYCLE

RELEASE WINDOW letters
RELEASE POPUPS _px90z5n6m

#REGION 0
IF m.talkstat = "ON"
	SET TALK ON
ENDIF
IF m.compstat = "ON"
	SET COMPATIBLE ON
ENDIF


*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║                  LETTERS Cleanup Code                   ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*

#REGION 1
*
* PRINTLETTER - Print mail merge letter for a selected person.
*
PROCEDURE printletter
PRIVATE m.recno

SET CONSOLE OFF
SET PRINTER ON
SET TEXTMERGE ON

_PCOPIES = 1
PRINTJOB
	
IF m.prnscope = 1
	\<<letters.Letter>>
	EJECT PAGE
ELSE
	IF NOT EMPTY(forexpr)
		forexpr = "FOR "+forexpr
	ENDIF
	IF NOT EMPTY(whileexpr)
		whileexpr = "WHILE "+whileexpr
	ENDIF
	
	SELECT (m.savearea)
	m.recno = RECNO()
	
	SCAN &forexpr &whileexpr
		\<<letters.Letter>>
		EJECT PAGE
	ENDSCAN
	GOTO RECORD m.recno
ENDIF
	
ENDPRINTJOB
SET PRINTER OFF
SET CONSOLE ON
SET TEXTMERGE OFF
	
SELECT letters

*
* SHOWLETTER - Display the selected letter.
*
PROCEDURE showletter
PRIVATE m.width, m.hight

m.width = IIF(SROW()=50,46,21)
m.hight = 78
	
DEFINE WINDOW display ;
	FROM INT((SROW()-m.width)/2),INT((SCOL()-m.hight)/2) ;
	TO INT((SROW()-m.width)/2)+m.width-1,INT((SCOL()-m.hight)/2)+m.hight-1 ;
	FLOAT GROW CLOSE ZOOM SHADOW MINIMIZE SYSTEM ;
	COLOR SCHEME 8
	
MODI MEMO letter WINDOW display NOEDIT
RELEASE WINDOW display
	
RETURN .F.

