*       ║                                                         ║
*       ║ _PX90Z5NRQ           m.prnscope VALID                   ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         LETTERS,     Record Number:    9   ║
*       ║ Variable:            m.prnscope                         ║
*       ║ Called By:           VALID Clause                       ║
*       ║ Object Type:         Radio Button                       ║
*       ║ Snippet Number:      4                                  ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px90z5nrq     &&  m.prnscope VALID
#REGION 1
IF m.prnscope = 1
	SHOW GET m.for   DISABLE
	SHOW GET m.while DISABLE
ELSE
	SHOW GET m.for   ENABLE
	SHOW GET m.while ENABLE
ENDIF


*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX90Z5NZ1           m.for VALID                        ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         LETTERS,     Record Number:   10   ║
*       ║ Variable:            m.for                              ║
*       ║ Called By:           VALID Clause                       ║
*       ║ Object Type:         Check Box                          ║
*       ║ Snippet Number:      5                                  ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px90z5nz1     &&  m.for VALID
#REGION 1
PRIVATE m.area
m.area = SELECT()
SELECT (m.savearea)
	
IF EMPTY(forexpr)
	GETEXPR "Enter FOR expression:" ;
		TO forexpr TYPE 'L'
ELSE
	GETEXPR "Enter FOR expression:" ;
		TO forexpr TYPE 'L' DEFAULT forexpr
ENDIF

m.for = IIF(EMPTY(forexpr), 0, 1)
SHOW GET m.for	

SELECT (m.area)
RETURN .T.

*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX90Z5O4M           m.while VALID                      ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         LETTERS,     Record Number:   11   ║
*       ║ Variable:            m.while                            ║
*       ║ Called By:           VALID Clause                       ║
*       ║ Object Type:         Check Box                          ║
*       ║ Snippet Number:      6                                  ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px90z5o4m     &&  m.while VALID
#REGION 1
PRIVATE m.area
	m.area = SELECT()
	SELECT (m.savearea)

	IF EMPTY(whileexpr)
		GETEXPR "Enter FOR expression:" ;
			TO whileexpr TYPE 'L'
	ELSE
		GETEXPR "Enter FOR expression:" ;
			TO whileexpr TYPE 'L' DEFAULT whileexpr
	ENDIF
	
	m.while = IIF(EMPTY(whileexpr), 0, 1)
	SHOW GET m.while	
	
	SELECT (m.area)
RETURN .T.

