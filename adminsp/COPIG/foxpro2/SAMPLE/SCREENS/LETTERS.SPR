*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px90z5nea     &&  m.lett WHEN
#REGION 1
IF letters.module <> m.module
	SHOW GET m.choice, 2 DISABLE
ELSE
	SHOW GET m.choice, 2 ENABLE
ENDIF

