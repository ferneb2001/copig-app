*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px90z5nin     &&  m.lett VALID
#REGION 1
DO showletter


*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX90Z5NM9           m.choice VALID                     ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         LETTERS,     Record Number:    8   ║
*       ║ Variable:            m.choice                           ║
*       ║ Called By:           VALID Clause                       ║
*       ║ Object Type:         Push Button                        ║
*       ║ Snippet Number:      3                                  ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px90z5nm9     &&  m.choice VALID
#REGION 1
DO CASE
CASE m.choice = "See Letter"
	DO showletter
CASE m.choice = "Print"
	IF PRINTSTATUS()
		WAIT WINDOW "Printing..." NOWAIT
		DO printletter
		CLEAR READ
	ELSE
		DO alert.spr WITH "Printer not ready"
	ENDIF
CASE m.choice = "Cancel"
	CLEAR READ
ENDCASE


