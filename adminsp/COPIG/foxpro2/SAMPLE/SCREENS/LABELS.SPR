*       ║                                                         ║
*       ║ _PX90Z5JQU           m.for VALID                        ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         LABELS,     Record Number:   11    ║
*       ║ Variable:            m.for                              ║
*       ║ Called By:           VALID Clause                       ║
*       ║ Object Type:         Check Box                          ║
*       ║ Snippet Number:      5                                  ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px90z5jqu     &&  m.for VALID
#REGION 1
IF EMPTY(forexpr)
	GETEXPR "Enter FOR expression:" TO forexpr TYPE 'L'
ELSE
	GETEXPR "Enter FOR expression:" TO forexpr TYPE 'L' DEFAULT forexpr
ENDIF
	
m.for = IIF(EMPTY(forexpr), 0, 1)
SHOW GET m.for	


