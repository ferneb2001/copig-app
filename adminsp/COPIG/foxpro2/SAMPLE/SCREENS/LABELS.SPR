FUNCTION _px90z5jvg     &&  m.while VALID
#REGION 1
IF EMPTY(whileexpr)
	GETEXPR "Enter FOR expression:" TO whileexpr TYPE 'L'
ELSE
	GETEXPR "Enter FOR expression:" TO whileexpr TYPE 'L' DEFAULT whileexpr
ENDIF
	
m.while = IIF(EMPTY(whileexpr), 0, 1)
SHOW GET m.while	


*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX90Z5K06           Read Level When                    ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         LABELS                             ║
*       ║ Called By:           READ Statement                     ║
*       ║ Snippet Number:      7                                  ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px90z5k06     && Read Level When
*
* When Code from screen: LABELS
*
#REGION 1
IF m.module = 'clients'
	m.memsize = 223000
ELSE
	m.memsize = 215000
ENDIF

IF VAL(SYS(1001)) < m.memsize
	SHOW GET m.choice, 2 DISABLE
ENDIF
	