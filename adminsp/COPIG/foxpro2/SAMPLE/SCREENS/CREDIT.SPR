*       ║                                                         ║
*       ║ _PX90P501C           m.newcardid VALID                  ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         CREDIT,     Record Number:   24    ║
*       ║ Variable:            m.newcardid                        ║
*       ║ Called By:           VALID Clause                       ║
*       ║ Object Type:         Field                              ║
*       ║ Snippet Number:      3                                  ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px90p501c     &&  m.newcardid VALID
#REGION 1
IF EMPTY(m.newcardid) OR ASCAN(cardids, m.newcardid)<>0
	WAIT WINDOW "You must enter a unique credit card id" NOWAIT
	RETURN .F.
ENDIF
	
m.idcnt = m.idcnt + 1
DIMENSION cardids[m.idcnt]

cardids[m.idcnt] = m.newcardid
= ASORT(cardids)
	
m.card_id = m.newcardid
m.newcardid = ""
SHOW GET m.newcardid DISABLE
SHOW GET m.card_id DISABLE
ON KEY LABEL esc

