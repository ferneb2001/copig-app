*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX90P53LN           m.seecharges VALID                 ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         CREDIT,     Record Number:   45    ║
*       ║ Variable:            m.seecharges                       ║
*       ║ Called By:           VALID Clause                       ║
*       ║ Object Type:         Push Button                        ║
*       ║ Snippet Number:      24                                 ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px90p53ln     &&  m.seecharges VALID
#REGION 1
REGIONAL savearea
PRIVATE chosenid

savearea = SELECT()
IF NOT locatedb("details",1)
	RETURN
ENDIF
SET SKIP OF POPUP cardinfo .T.
SET SKIP OF POPUP _MRECORD .T.
SET SKIP OF BAR 1 OF reports .T.
SET SKIP OF BAR 2 OF reports .T.

DEFINE WINDOW skipview ;
	FROM 2,4 ;
	TO 24,60 ;
	TITLE " All Charges [ESC to exit] " ;
	FLOAT ;
	CLOSE ;
	SYSTEM ;
	COLOR SCHEME 10

chosenid = m.card_id

SELECT DISTINCT credcard.type, details.trans_type, details.trans_date,;
	details.amt;
	FROM details, credcard;
	WHERE details.card_id = credcard.card_id;
	AND details.trans_type = "Charge";
	AND credcard.card_id = chosenid;
 	ORDER BY details.trans_date DESCENDING, details.amt DESCENDING;
	INTO CURSOR query
 		
BROWSE NOEDIT NOAPPEND NODELETE WIDTH 20;
	WINDOW skipview
		
USE
SELECT details
USE
SELECT (savearea)
SET SKIP OF POPUP cardinfo .F.
SET SKIP OF POPUP _MRECORD .F.
SET SKIP OF BAR 1 OF reports .F.
SET SKIP OF BAR 2 OF reports .F.

RELEASE WINDOW skipview

*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX90P53Y3           m.choice VALID                     ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         CONTROL2,     Record Number:    2  ║
*       ║ Variable:            m.choice                           ║
*       ║ Called By:           VALID Clause                       ║
*       ║ Object Type:         Push Button                        ║
*       ║ Snippet Number:      25                                 ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px90p53y3     &&  m.choice VALID
#REGION 2
DO CASE
CASE m.choice = "Next"
	SKIP 1
	IF EOF() OR RECNO() = m.bottomrec
		GO BOTTOM
		SHOW GET m.choice, 1 DISABLE
		SHOW GET m.choice, 4 DISABLE
	ELSE
		IF RECNO() > m.toprec
			SHOW GET m.choice, 2 ENABLE
			SHOW GET m.choice, 3 ENABLE
		ENDIF
	ENDIF
CASE m.choice = "Prior"
	SKIP -1
	IF BOF() OR RECNO() = m.toprec
		GO TOP
		SHOW GET m.choice, 2 DISABLE
		SHOW GET m.choice, 3 DISABLE
	ELSE
		IF RECNO() < m.bottomrec
			SHOW GET m.choice, 1 ENABLE
			SHOW GET m.choice, 4 ENABLE
		ENDIF
	ENDIF	
CASE m.choice = "Top"
	GO TOP	
	SHOW GET m.choice, 1 ENABLE
	SHOW GET m.choice, 2 DISABLE
	SHOW GET m.choice, 3 DISABLE
	SHOW GET m.choice, 4 ENABLE
CASE m.choice = "Bottom"
	GO BOTTOM
	SHOW GET m.choice, 1 DISABLE
	SHOW GET m.choice, 2 ENABLE
	SHOW GET m.choice, 3 ENABLE
	SHOW GET m.choice, 4 DISABLE
CASE m.choice = "Locate"
	DO browser.spr	
CASE m.choice = "OK"
	m.idlequit = .T.	
	m.quitting = .T.
	CLEAR READ
ENDCASE
SHOW GETS

