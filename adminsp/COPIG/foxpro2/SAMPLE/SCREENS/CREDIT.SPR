*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px90p530l     &&  m.saverecord WHEN
#REGION 1
IF EMPTY(m.card_no)
	?? CHR(7)
	WAIT WINDOW "Enter credit card number" NOWAIT
	_CUROBJ = OBJNUM(m.card_no)
	RETURN .F.
ELSE
	IF m.card_id = "New..."
		?? CHR(7)
		WAIT WINDOW "Select credit card id" NOWAIT
		_CUROBJ = OBJNUM(m.card_id)
		RETURN .F.
	ENDIF
ENDIF

*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX90P535E           m.saverecord VALID                 ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         CREDIT,     Record Number:   42    ║
*       ║ Variable:            m.saverecord                       ║
*       ║ Called By:           VALID Clause                       ║
