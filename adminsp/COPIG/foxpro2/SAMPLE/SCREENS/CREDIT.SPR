*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX90P51YZ           m.balance VALID                    ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         CREDIT,     Record Number:   39    ║
*       ║ Variable:            m.balance                          ║
*       ║ Called By:           VALID Clause                       ║
*       ║ Object Type:         Push Button                        ║
*       ║ Snippet Number:      18                                 ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px90p51yz     &&  m.balance VALID
#REGION 1
PRIVATE m.saverec, m.credits, m.debits, m.date, m.month, m.day, m.scope

m.month = MONTH(DATE())
m.scope = 1
DO balance.spr WITH m.month, m.scope
IF m.month = 0
	RETURN
ENDIF

IF USED("details")
	SELECT details
ELSE
	SELECT 0
	USE LOCFILE("details.dbf","DBF","Where is DETAILS.DBF?")
ENDIF

m.day  = DAY(GOMONTH(CTOD(STR(m.month,2)+"/01/"+STR(YEAR(DATE()),4)),1)-1)
m.date = CTOD(STR(m.month)+"/"+STR(m.day)+"/"+STR(YEAR(DATE())))
m.saverec = RECNO()

SET ESCAPE OFF
IF m.scope = 1
	DO balanceone
ELSE
	DO balanceall
ENDIF
SET ESCAPE ON
SET TALK NOWINDOW
IF m.scope <> 1
	WAIT WINDOW "All records balanced" NOWAIT
ENDIF

*
* SETTALKWIN - Setup TALK WINDOW.
*
PROCEDURE settalkwin

DEFINE WINDOW talkwindow ;
	FROM 1,48 TO 3,76 ;
	NOFLOAT NOCLOSE SHADOW ;
	COLOR SCHEME 5
ACTIVATE WINDOW talkwindow
	
SET NOTIFY ON
SET TALK WINDOW talkwindow
SET TALK ON

*
* SUMTHEM - Sum credits and debits.
*
PROCEDURE sumthem

SUM FOR (details.card_id = credcard.card_id AND ;
	details.trans_date<=m.date AND ;
	details.trans_date>credcard.baldate AND ;
	(ALLTRIM(details.trans_type) = "Payment" OR ;
	ALLTRIM(details.trans_type) = "Deposit"));
	TO m.credits
	
GO TOP
SUM FOR (details.card_id = credcard.card_id AND ;
	details.trans_date<=m.date AND ;
	details.trans_date>credcard.baldate AND ;
	(ALLTRIM(details.trans_type) = "Charge" OR ;
	ALLTRIM(details.trans_type) = "Fee" OR ;
	ALLTRIM(details.trans_type) = "Interest" OR ;
	ALLTRIM(details.trans_type) = "Expense" ));
	TO m.debits

*
* BALANCEONE - Balance current credit card account.
*
PROCEDURE balanceone

IF m.baldate >= m.date
	WAIT WINDOW "Account balanced as of "+DTOC(m.baldate) NOWAIT
	RETURN
ENDIF

m.credits = 0
m.debits  = 0
m.saverec = RECNO()
m.savearea = SELECT()
IF USED("details")
	SELECT details
ELSE
	SELECT 0
	USE LOCFILE("details.dbf","DBF","Where is DETAILS.DBF?")
ENDIF
GO TOP

DO settalkwin
DO sumthem

SET TALK OFF
RELEASE WINDOW talkwindow

WAIT WINDOW STR(m.debits - m.credits,10,2) TIMEOUT 1
m.startbal = m.startbal - m.credits + m.debits
m.baldate = m.date

USE
SELECT credcard
GOTO RECORD m.saverec

=showsave()
SHOW GET m.startbal

*
* BALANCEALL - Balance all credit card accounts.
*
PROCEDURE balanceall
PRIVATE m.firstfound

m.firstfound = .T.

SELECT credcard
GO TOP

SCAN
	m.credits = 0
	m.debits  = 0

	IF credcard.baldate < m.date
		IF m.firstfound
			DO settalkwin
			m.firstfound = .F.
		ENDIF
		
		SELECT details
		GO TOP
		SET TALK ON

		DO sumthem
		
		SET TALK OFF
		SELECT credcard
	
		REPLACE credcard.startbal WITH ;
			credcard.startbal - m.credits + m.debits
		REPLACE credcard.baldate WITH m.date
	ENDIF
ENDSCAN

SELECT details
USE
SELECT credcard
GOTO RECORD m.saverec
SHOW GETS
RELEASE WINDOW talkwindow
SET TALK OFF


