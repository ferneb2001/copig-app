*       ║ _PX90P51FE           m.user Popup From                  ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         CREDIT,     Record Number:   36    ║
*       ║ Variable:            m.user                             ║
*       ║ Called By:           Popup From Clause                  ║
*       ║ Object Type:         List                               ║
*       ║ Snippet Number:      15                                 ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px90p51fe     &&  m.user Popup From
#REGION 1
PRIVATE m.cnt, m.limit
m.cnt = 1
m.limit = ALEN(users,1)
DO WHILE m.cnt <= m.limit
	IF EMPTY(users[m.cnt,1])
		RETURN m.cnt-1
	ENDIF
	m.cnt = m.cnt + 1
ENDDO
RETURN m.cnt-1

*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX90P51KD           m.otheruser VALID                  ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         CREDIT,     Record Number:   37    ║
*       ║ Variable:            m.otheruser                        ║
*       ║ Called By:           VALID Clause                       ║
*       ║ Object Type:         Push Button                        ║
*       ║ Snippet Number:      16                                 ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px90p51kd     &&  m.otheruser VALID
#REGION 1
PRIVATE usercpy, m.osize, m.nsize, m.i

m.osize = size(ALEN(users, 1))
IF m.osize > 0
	DIMENSION usercpy[m.osize]
	FOR m.i = 1 TO m.osize
		usercpy[m.i] = users[m.i,3]
	ENDFOR
ENDIF
	
IF NOT addusers(m.card_no)
	RETURN
ENDIF

SHOW GET user
	
m.nsize = size(ALEN(users, 1))
IF m.nsize = 0 AND m.osize = 0
	RETURN
ENDIF
IF m.nsize <> m.osize OR m.nsize = 0
	= showsave()
	RETURN
ENDIF
DIMENSION users[m.nsize,3]

m.i = 1
= ASORT(usercpy)
= ASORT(users,3)
DO WHILE m.i<=m.osize
	IF usercpy[m.i]<>users[m.i,3]
		= showsave()
		RETURN
	ELSE
		m.i = m.i + 1
	ENDIF
ENDDO

*
* SIZE
*
FUNCTION size
PARAMETER m.limit
PRIVATE m.cnt
m.cnt = 1
DO WHILE m.cnt <= m.limit
	IF EMPTY(users[m.cnt,1])
		RETURN m.cnt-1
	ENDIF
	m.cnt = m.cnt + 1
ENDDO
RETURN m.cnt-1

