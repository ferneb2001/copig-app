#REGION 2
*
* Screen description:
* This screen is a UTILITY screen.  It may be combined with any other
* screens.  All variables used by this screen have been declared REGIONAL to
* encapsulate them (i.e., to avoid conflict with variables from other
* screens).  All variables also have 'm.' prefix to avoid conflict with
* 'unknown' database field names.
*
* Points of interest:
* This screen has been designed to dim its buttons when they
* are not appropritate (i.e., when at TOP dim < Top >, etc.)
* Since TOP and BOTTOM operate within a given scope, if you wish to use this
* screen in presence of any FILTERING (scope altering) conditions make sure
* the control utility screen follows the other screen when you combine them.
*


#REGION 0
REGIONAL m.currarea, m.talkstat, m.compstat

IF SET("TALK") = "ON"
	SET TALK OFF
	m.talkstat = "ON"
ELSE
	m.talkstat = "OFF"
ENDIF
m.compstat = SET("COMPATIBLE")
SET COMPATIBLE FOXPLUS

*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║         S9197087 Databases, Indexes, Relations          ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*

IF USED("credcard")
	SELECT credcard
	SET ORDER TO 0
ELSE
	SELECT 0
	USE (LOCFILE("dbfs\credcard.dbf","DBF","Where is credcard?"));
		AGAIN ALIAS credcard ;
		ORDER 0
ENDIF

IF USED("carduser")
	SELECT carduser
	SET ORDER TO 0
ELSE
	SELECT 0
	USE (LOCFILE("dbfs\carduser.dbf","DBF","Where is carduser?"));
		AGAIN ALIAS carduser ;
		ORDER 0
ENDIF

SELECT credcard


*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║                    Window definitions                   ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*

IF NOT WEXIST("credit")
	DEFINE WINDOW credit ;
		FROM 2, 5 ;
		TO 24,60 ;
		TITLE " Credit Card Manager " ;
		FLOAT ;
		NOCLOSE ;
		SHADOW ;
		COLOR SCHEME 1
ENDIF

IF NOT WEXIST("controls")
	DEFINE WINDOW controls ;
		FROM 2, 63 ;
		TO 24,74 ;
		FLOAT ;
		NOCLOSE ;
		SHADOW ;
		COLOR SCHEME 1
ENDIF


*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║              CREDIT Setup Code - SECTION 2              ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*

#REGION 1
m.baldate=DATE()
SET RESO TO ORGUSER

IF EMPTY(FILTER())
	SET FILTER TO NOT EMPTY(card_id)
	GO TOP
ENDIF

DIMENSION users [1,3]
DIMENSION authoris [10]
DIMENSION cardids [1]

m.adding  = .F.
m.editing = .F.
m.idcnt = 0
m.saverec = RECNO()

SCAN FOR NOT DELETED()
	m.string = ALLTRIM(Card_id)
	IF NOT EMPTY(m.string) AND ASCAN(cardids, m.string) = 0
		m.idcnt = m.idcnt + 1
		IF m.idcnt > ALEN(cardids)
			DIMENSION cardids[m.idcnt]
		ENDIF
		cardids[m.idcnt] = m.string
	ENDIF
ENDSCAN

= ASORT(cardids)

GOTO RECORD m.saverec
SCATTER MEMVAR MEMO

*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║             CONTROL2 Setup Code - SECTION 2             ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*

#REGION 2
REGIONAL m.choice, m.toprec, m.bottomrec, m.saverecno
PRIVATE m.quitting
m.quitting = .F.
m.choice = "OK"

IF EOF()
	GO BOTTOM
ENDIF

m.saverecno = RECNO()
GO TOP
m.toprec = RECNO()
GO BOTTOM
m.bottomrec = RECNO()
GO m.saverecno



