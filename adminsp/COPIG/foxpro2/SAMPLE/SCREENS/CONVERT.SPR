*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX90P3PTS           m.unittype VALID                   ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         CONVERT,     Record Number:   15   ║
*       ║ Variable:            m.unittype                         ║
*       ║ Called By:           VALID Clause                       ║
*       ║ Object Type:         Radio Button                       ║
*       ║ Snippet Number:      5                                  ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px90p3pts     &&  m.unittype VALID
#REGION 1
PRIVATE m.i, m.size
	
SELECT DISTINCT units.unit ;
	FROM units ;
	WHERE units.type = m.unittype ;
	ORDER BY units.type ;
   	INTO ARRAY fromarry
		
m.size = ALEN(fromarry)
DIMENSION toarry[m.size]
FOR m.i = 1 TO m.size
	fromarry[m.i] = ALLTRIM(fromarry[m.i])
	toarry[m.i] = fromarry[m.i]
ENDFOR

m.frompop = fromarry[1]
m.topop   = toarry[1]	
m.fromval = SPACE(19)
m.toval   = SPACE(19)

_CUROBJ = OBJNUM(m.fromval)
SHOW GETS
	

