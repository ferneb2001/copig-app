FUNCTION _px90p3pal     &&  m.frompop VALID
#REGION 1
IF EMPTY(m.fromval)
	_CUROBJ = OBJNUM(m.fromval)
	SHOW GET m.fromval
	RETURN .F.
ENDIF
= convrt (m.fromval, m.toval, "left")


