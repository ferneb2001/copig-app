*       ║                                                         ║
*       ║                    Window definitions                   ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*

IF NOT WEXIST("trans")
	DEFINE WINDOW trans ;
		FROM 2, 6 ;
		TO 24,57 ;
		TITLE (m.mytitle) ;
		FLOAT ;
		NOCLOSE ;
		SHADOW ;
		COLOR SCHEME 1
ENDIF

IF NOT WEXIST("controls")
	DEFINE WINDOW controls ;
		FROM 2, 61 ;
		TO 24,72 ;
		FLOAT ;
		NOCLOSE ;
		SHADOW ;
		COLOR SCHEME 1
ENDIF


*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║              TRANS Setup Code - SECTION 2               ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*

#REGION 1
m.clientid = ""
m.accnt    = ""
m.adding   = .F.
m.editing  = .F.

DIMENSION cardidary[1]
DIMENSION accntary [1]
DIMENSION clientary[1]

SCATTER MEMVAR MEMO BLANK

m.cards = "American Express"
SELECT DISTINCT credcard.card_id ;
	FROM credcard ;
	WHERE credcard.type = m.cards ;
	INTO ARRAY cardidary

m.card_id = cardidary[1]

SELECT DISTINCT ALLTRIM(credcard.acct_id)+" "+ALLTRIM(credcard.type) ;
	FROM credcard ;
	WHERE credcard.acct_id <> "         " ;
	INTO ARRAY accntary
	
m.accnt = accntary[1]

SELECT DISTINCT clients.company ;
	FROM clients ;
	INTO ARRAY clientary

m.client = clientary[1]

*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║             CONTROL2 Setup Code - SECTION 2             ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*

#REGION 2
REGIONAL m.choice, m.toprec, m.bottomrec, m.saverecno
PRIVATE m.quitting
m.quitting = .F.
m.choice = "OK"

IF EOF()
	GO BOTTOM
ENDIF

m.saverecno = RECNO()
GO TOP
m.toprec = RECNO()
GO BOTTOM
m.bottomrec = RECNO()
GO m.saverecno



