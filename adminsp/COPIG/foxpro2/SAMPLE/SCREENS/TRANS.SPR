*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX90Z4MQZ           Read Level Show                    ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         Multiple Screens                   ║
*       ║ Called By:           READ Statement                     ║
*       ║ Snippet Number:      23                                 ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px90z4mqz     && Read Level Show
PRIVATE currwind
STORE WOUTPUT() TO currwind
*
* Show Code from screen: TRANS
*
#REGION 1
IF NOT m.adding
	SCATTER MEMVAR MEMO

	SHOW GET m.service
	
	m.client = clients.company
	IF NOT EMPTY(m.client)
		m.clitrans = 1
	ENDIF
	
	SHOW GET m.trans_date
	SHOW GET m.amt
	SHOW GET m.check_no
	SHOW GET m.trans_type
	
	IF NOT EMPTY(m.card_id)
		m.decider = 1
		m.cards = credcard.type
	ELSE
		m.cards = ""
	ENDIF
	m.accnt = ""
	IF NOT EMPTY(m.acct_id)
		m.decider = 2
		m.accnt = ALLTRIM(cards2.acct_id)+" "+ALLTRIM(cards2.type)
	ENDIF
	= refresh()
ENDIF
*
* Show Code from screen: CONTROL2
*
#REGION 2
IF EOF()
	GO BOTTOM
ENDIF

m.saverecno = RECNO()
GO TOP
m.toprec = RECNO()
GO BOTTOM
m.bottomrec = RECNO()
GO m.saverecno

IF RECNO() = m.bottomrec
	SHOW GET m.choice, 1 DISABLE
	SHOW GET m.choice, 2 ENABLE
	SHOW GET m.choice, 3 ENABLE
	SHOW GET m.choice, 4 DISABLE
ELSE
	IF RECNO() = m.toprec
		SHOW GET m.choice, 1 ENABLE
		SHOW GET m.choice, 2 DISABLE
		SHOW GET m.choice, 3 DISABLE
		SHOW GET m.choice, 4 ENABLE
	ELSE
		SHOW GET m.choice ENABLE
	ENDIF
ENDIF

IF NOT EMPTY(currwind)
	ACTIVATE WINDOW (currwind) SAME
ENDIF