*       ║ Snippet Number:      7                                  ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px90z4kgd     &&  m.client VALID
#REGION 1
PRIVATE m.savreco

m.savereco = RECNO()
SELECT clients
IF m.client<>clients.company
	= showsave()
ENDIF
LOCATE FOR clients.company = m.client

m.clientid = clients.client_id

SELECT details
GOTO RECORD m.savereco

