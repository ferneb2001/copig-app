_DBCLICK 	N 		0.5
_DIARYDATE 	D 		Current date
_GENGRAPH	C		GENGRAPH.PRG
_GENMENU	C		GENMENU.PRG
_GENPD		C		GENPD.APP
_GENSCRN	C		GENSCRN.PRG
_INDENT 	N 		0
_LMARGIN 	N 		0
_MLINE		N		0
_PADVANCE 	C 		FORMFEED
_PAGENO 	N 		1
_PBPAGE 	N 		1
_PCOLNO 	N 		Current column
_PCOPIES 	N 		1
_PDRIVER 	C 		Assigned default
_PDSETUP	C		Null string
_PECODE 	C 		Null string
_PEJECT 	C 		BEFORE
_PEPAGE 	N 		32767
_PFORM 		C 		Null string
_PLENGTH 	N 		66
_PLINENO 	N 		0
_PLOFFSET 	N 		0 
_PPITCH 	C 		DEFAULT
_PQUALITY 	L 		.F.
