         Program Example         

CLOSE ALL
SELECT 0
USE customer

SET FILTER TO !EMPTY(comments)
?FILTER()

STORE FILTER('customer') TO savefilt  && Save filter expression
SET FILTER TO state = 'OH'
?FILTER()

SET FILTER TO &savefilt  && Restore filter
?FILTER()



