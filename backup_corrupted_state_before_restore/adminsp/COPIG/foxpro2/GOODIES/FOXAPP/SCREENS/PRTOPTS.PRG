*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px00mevum     &&  reptrb VALID
#REGION 1
DO CASE
CASE reptrb = 1
   lastpd = IIF(pdrivrb=0,lastpd,pdrivrb)
   pdrivrb = 0
   SHOW GET pdrivrb DISABLE
CASE reptrb = 2
   lastpd = IIF(pdrivrb=0,lastpd,pdrivrb)
   pdrivrb = 0
   SHOW GET pdrivrb DISABLE
CASE reptrb = 3
   pdrivrb = lastpd
   SHOW GET pdrivrb ENABLE
ENDCASE
createrb = 0
layoutrb = 0
SHOW GET layoutrb DISABLE
SHOW GET createrb

*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX00MEWEO           okcancl VALID                      ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         PRTOPTS,     Record Number:    4   ║
*       ║ Variable:            okcancl                            ║
*       ║ Called By:           VALID Clause                       ║
*       ║ Object Type:         Push Button                        ║
*       ║ Snippet Number:      2                                  ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px00meweo     &&  okcancl VALID
#REGION 1
IF OKcancl = 1
   DO CASE
   CASE createrb = 1
      m.repname = UPPER(ALLTRIM(PUTFILE('Report form','','FRX')))
      IF !EMPTY(m.repname)
         IF layoutrb = 1
            CREATE REPORT (m.repname) FROM (m.dbfname) FORM
         ELSE
            CREATE REPORT (m.repname) FROM (m.dbfname) COLUMN
         ENDIF
         MODIFY REPORT (m.repname)
      ENDIF
   CASE reptrb = 1
      MODIFY REPORT ?
   CASE reptrb = 2
      DO prtsetup
   CASE reptrb = 3
      DO CASE
      CASE pdrivrb = 1
         DO putprt WITH ""
      CASE pdrivrb = 2
         DO putprt WITH "PDRIVER"
      CASE pdrivrb = 3
         _pdriver = ""
         DO putprt WITH ""
      ENDCASE
   ENDCASE
ELSE
   CLEAR READ
ENDIF




