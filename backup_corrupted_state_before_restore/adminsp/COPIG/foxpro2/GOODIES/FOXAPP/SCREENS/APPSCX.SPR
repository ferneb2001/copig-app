*       ║ Snippet Number:      5                                  ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px00lw7s4     &&  Listdbf VALID
#REGION 1
origname = dbfname
CLOSE DATABASES
dbfname = GETFILE('DBF','Database name')
IF EMPTY(dbfname)
   dbfname = origname
ELSE
   =opendbf(dbfname)
   IF EMPTY(scxname)
      scxname = forceext(dbfname,'SCX')
   ENDIF
ENDIF
SHOW GETS
RETURN .T.


