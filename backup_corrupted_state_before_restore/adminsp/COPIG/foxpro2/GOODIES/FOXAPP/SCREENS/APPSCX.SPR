*
FUNCTION _px00lwaar     &&  Listscx VALID
#REGION 1
origname = scxname
scxname = GETFILE('SCX','Screen file name')
IF EMPTY(scxname)
   scxname = origname
ENDIF
SHOW GETS
RETURN .T.


*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX00LWAQZ           generate VALID                     ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         APPSCX,     Record Number:   16    ║
*       ║ Variable:            generate                           ║
*       ║ Called By:           VALID Clause                       ║
*       ║ Object Type:         Push Button                        ║
*       ║ Snippet Number:      12                                 ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px00lwaqz     &&  generate VALID
#REGION 1
PRIVATE win_string, dname, quoted, sc_file
IF m.generate = 1

   IF EMPTY(m.dbfname) OR !FILE(m.dbfname)
      SHOW GETS
      RETURN -8   && bounce out of the valid
   ENDIF

   SET CURSOR OFF

   IF EMPTY(m.scxname)
      m.scxname = forceext(m.dbfname,'SCX')
   ENDIF
   IF !FILE(m.scxname)
      DO createscx
   ENDIF

   CLOSE DATABASES
   m.scxname  = UPPER(ALLTRIM(m.scxname))
   m.dbfname  = UPPER(ALLTRIM(m.dbfname))
   m.mnuname  = UPPER(ALLTRIM(m.mnuname))

   SET CURSOR ON

   m.appfile = forceext(m.scxname,'APP')
   m.appfile = PUTFILE('Name your application:',forceext(m.appfile,'APP'),'APP')
   IF EMPTY(m.appfile)
      SHOW GETS
   ELSE
      SET CONSOLE OFF
      tmfname = AddBs(Justpath(m.appfile))+'startup.prg'
      SET TEXTMERGE TO (m.tmfname)

      SET TEXTMERGE ON

      \\*       ╓─────────────────────────────────────────────────────────╖
      \*       ║                                                         ║
      \*       ║ <<DATE()>>               startup.prg             <<TIME()>> ║
      \*       ║                                                         ║
      \*       ╟─────────────────────────────────────────────────────────╢
      \*       ║                                                         ║
      \*       ║ Description:                                            ║
      \*       ║ This program was automatically generated by FoxApp.     ║
      \*       ║                                                         ║
      \*       ╙─────────────────────────────────────────────────────────╜
      \*
      \*       To run this application, type DO <<UPPER(justfname(m.appfile))>>
      \*
      \* Set up runtime environment
      \CREATE VIEW appview
      \PUSH MENU _msysmenu
      \SET SAFETY OFF
      \SAVE MACROS TO foxapp
      \SET SAFETY ON
      \SET TALK OFF
      \SET DELETED ON
      \SET ESCAPE OFF
      \SET STEP OFF
      \SET ECHO OFF
      \SET PROCEDURE TO appproc.prg
      \SET CURSOR ON
      \ON ERROR DO apperror WITH PROGRAM(),MESSAGE(),MESSAGE(1),LINENO(),ERROR()

      \IF TYPE("BAILOUT") <> "U"
      \   RELEASE bailout
      \ENDIF
      \IF TYPE("DBFNAME") <> "U"
      \   RELEASE dbfname
      \ENDIF
      \IF TYPE("WIN_NAME") <> "U"
      \   RELEASE win_name
      \ENDIF
      \IF TYPE("FILT_EXPR") <> "U"
      \   RELEASE filt_expr
      \ENDIF
      \IF TYPE("SRCHTERM") <> "U"
      \   RELEASE srchterm
      \ENDIF

      \PUBLIC bailout, dbfname, win_name, filt_expr, srchterm
      \m.bailout = .F.
      \m.dbfname = "<<m.dbfname>>"     && database name
      \m.filt_expr = ""                && filter expression, if any
      \m.srchterm = SPACE(60)          && search term

      _mname = forceext(juststem(m.mnuname),'PRG')
      \DO <<_mname>>

	   \m.stem = juststem(m.dbfname)
      \IF USED(m.stem)
      \   SELECT (m.stem)
      \ELSE
      \   SELECT 0
      \   m.dbfname = LOCFILE(m.dbfname,'DBF','Please locate the '+JustStem(m.dbfname)+' database')
      \   IF EMPTY(m.dbfname)
      \      DO alert WITH "The "+m.stem+" database;could not be found."
      \      DO cleanup
      \   ELSE
      \      USE (m.dbfname)
      \   ENDIF
      \ENDIF
      \SET ORDER TO 1

      \IF RECCOUNT() = 0
      \   APPEND BLANK
      \ENDIF
      \GOTO TOP

      \CLEAR

      sc_file = LOWER(forceext(juststem(m.scxname),'SPR'))

      * Force user screen into a window and figure out its size
      vcoord = 0
      hcoord = 0
      IF FILE(m.scxname)
         SELECT 0
         USE (m.scxname) ALIAS scrnfile

         * Make sure that user screen goes into a window
         IF EMPTY(scrnfile->name)
            win_msg = "Putting "+Juststem(m.scxname)+" screen into window"
            WAIT WINDOW win_msg TIMEOUT 1

            REPLACE scrnfile->name WITH juststem(m.appfile), ;
                    scrnfile->style WITH 1,                  ;
                    scrnfile->center WITH .F.,               ;
                    scrnfile->width WITH SCOLS()-6,          ;
                    scrnfile->height WITH SROWS()-4,         ;
                    scrnfile->vpos WITH 1,                   ;
                    scrnfile->hpos WITH 3,                   ;
                    scrnfile->scheme WITH 1,                 ;
                    scrnfile->scheme2 WITH 2
            WAIT CLEAR
         ENDIF
         win_name = UPPER(ALLTRIM(scrnfile->name))

         IF scrnfile.center
            vcoord = (SROWS() + scrnfile.height) / 2 + 2
         ELSE
            vcoord = scrnfile.vpos + scrnfile.height + 1
         ENDIF
         hcoord = 3  && panel is 73 characters wide
         IF vcoord + 3 > SROWS()
            vcoord = SROWS()-3
         ENDIF
         vcoord = INT(vcoord)
         hcoord = INT(hcoord)

         REPLACE FLOAT WITH .T., CLOSE WITH .T.
         USE
      ENDIF
      \win_name = "<<win_name>>"

      \DO WHILE !bailout
      \   KEYBOARD "{PGDN}"
      \   * Display the screen control panel
      \   DO appctrl WITH MIN(<<vcoord>>,SROWS()-3),<<hcoord>>
      \   * Display the main screen file
      \   DO <<sc_file>>
      \ENDDO
      \DO cleanup
      \RETURN
      \
      \
      \PROCEDURE cleanup
      \* Clean up after the application
      \SET PROCEDURE TO
      \CLOSE DATABASES
      \CLEAR WINDOWS

      \t_stat = SET("TALK")
      \SET TALK OFF
      \* Restore databases, indexes and environment
      \IF FILE("appview.vue")
      \   SET VIEW TO appview
      \   SET TALK OFF
      \   DELETE FILE appview.vue
      \ENDIF

      \IF FILE("foxapp.fky")
      \   RESTORE MACROS FROM foxapp
      \   DELETE FILE foxapp.fky
      \ENDIF
      \IF t_stat = "ON"
      \   SET TALK ON
      \ENDIF
      \POP MENU _msysmenu
      \CLEAR PROGRAM
      \ON ERROR
      \SET SAFETY ON
      \RETURN


      SET TEXTMERGE TO
      SET TEXTMERGE OFF
      SET CONSOLE ON

      win_string = "Generating application "+PROPER(juststem(m.appfile))
      WAIT WINDOW win_string NOWAIT
      HIDE WINDOW (WOUTPUT())

      SET NOTIFY OFF

      m.appname  = UPPER(ALLTRIM(m.appfile))
      m.projname = forceext(m.appname,'PJX')
      IF FILE(m.projname)
         DELETE FILE (m.projname)
      ENDIF
      pjtname = forceext(m.projname,'PJT')
      IF FILE(m.pjtname)
         DELETE FILE (m.pjtname)
      ENDIF

      * Build the actual application project file and APP now
      BUILD PROJECT (m.projname) FROM ;
         (m.tmfname),                 ;
         appproc.prg,appmenu.prg,     ;
         prtsetup.prg, getdest.prg,   ;
         getorder.prg, appabout.prg,  ;
         appsrch.prg, (m.scxname)
      BUILD APP (m.appname) FROM (m.projname)

      SET NOTIFY ON

      CLEAR READ
   ENDIF
ENDIF
RETURN .T.




*       ╓─────────────────────────────────────────────────────────╖
