*       ║ Object Type:         Field                              ║
*       ║ Snippet Number:      7                                  ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px00lw8mw     &&  scxname VALID
#REGION 1
SET CURSOR OFF
m.scxname = STRTRAN(m.scxname,'\\','\')
scxname = ALLTRIM(m.scxname)
IF !('.' $ justfname(m.scxname)) AND !EMPTY(m.scxname)
   scxname = forceext(m.scxname,'SCX')
ENDIF
m.scxname = UPPER(m.scxname)
SHOW GETS


*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX00LW91P           addscx VALID                       ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         APPSCX,     Record Number:   13    ║
*       ║ Variable:            addscx                             ║
*       ║ Called By:           VALID Clause                       ║
*       ║ Object Type:         Push Button                        ║
*       ║ Snippet Number:      8                                  ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px00lw91p     &&  addscx VALID
#REGION 1
IF EMPTY(m.scxname)
   m.scxname = PUTFILE('Screen file name','','SCX')
   IF EMPTY(m.scxname)
      m.scxname = 'UNTITLED.SCX'
   ENDIF
ELSE
   IF FILE(m.scxname)
      MODIFY SCREEN (m.scxname)
   ELSE
      DO createscx
   ENDIF
   SHOW GET modscx ENABLE
   SHOW GET addscx DISABLE
ENDIF
SHOW GETS
RETURN .T.


*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX00LW9JY           modscx WHEN                        ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         APPSCX,     Record Number:   14    ║
*       ║ Variable:            modscx                             ║
*       ║ Called By:           WHEN Clause                        ║
*       ║ Object Type:         Push Button                        ║
*       ║ Snippet Number:      9                                  ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px00lw9jy     &&  modscx WHEN
#REGION 1
IF !FILE(m.scxname)
   WAIT WINDOW 'Creating screen file' NOWAIT
   DO createscx
ENDIF
RETURN .T.


*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX00LW9VP           modscx VALID                       ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         APPSCX,     Record Number:   14    ║
*       ║ Variable:            modscx                             ║
*       ║ Called By:           VALID Clause                       ║
*       ║ Object Type:         Push Button                        ║
*       ║ Snippet Number:      10                                 ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px00lw9vp     &&  modscx VALID
#REGION 1
IF FILE(m.scxname) AND !EMPTY(m.scxname)
   MODIFY SCREEN (m.scxname)
ELSE
   WAIT WINDOW "Creating screen" NOWAIT
   DO createscx
ENDIF
SHOW GET addscx DISABLE
SHOW GETS
RETURN .T.


*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX00LWAAR           Listscx VALID                      ║
*       ║                                                         ║
