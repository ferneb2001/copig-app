*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX00LW63F           dbfname VALID                      ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         APPSCX,     Record Number:    8    ║
*       ║ Variable:            dbfname                            ║
*       ║ Called By:           VALID Clause                       ║
*       ║ Object Type:         Field                              ║
*       ║ Snippet Number:      2                                  ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px00lw63f     &&  dbfname VALID
#REGION 1
SET CURSOR OFF
m.dbfname = STRTRAN(m.dbfname,'\\','\')
DO CASE
CASE justext(m.dbfname) = 'SCX'
   DO errshow WITH "A screen file name is not allowed here"
   RETURN 0
CASE justext(m.dbfname) = 'MNX'
   DO errshow WITH "A menu file name is not allowed here"
   RETURN 0
OTHERWISE
   IF !('.' $ justfname(m.dbfname)) AND !EMPTY(m.dbfname)
      m.dbfname = forceext(m.dbfname,'DBF')
   ENDIF

   dbfname = UPPER(ALLTRIM(m.dbfname))
   IF !EMPTY(m.dbfname)
      m.dbfalias = opendbf(m.dbfname)
   ENDIF

   IF EMPTY(m.scxname) AND !EMPTY(m.dbfname)
      m.scxname = forceext(m.dbfname,'SCX')
   ENDIF

   skipdbfbut = .F.
   SHOW GETS
   RETURN .T.
ENDCASE


*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX00LW6RH           adddbf VALID                       ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         APPSCX,     Record Number:    9    ║
*       ║ Variable:            adddbf                             ║
*       ║ Called By:           VALID Clause                       ║
*       ║ Object Type:         Push Button                        ║
*       ║ Snippet Number:      3                                  ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px00lw6rh     &&  adddbf VALID
#REGION 1
IF EMPTY(m.dbfname)
   m.dbfname = PUTFILE('Database name','','DBF')
   IF EMPTY(m.dbfname)
      RETURN .F.   && don't do anything
   ENDIF
ENDIF
IF FILE(m.dbfname)
   m.dname = opendbf(m.dbfname)
   IF !EMPTY(m.dname)
      MODIFY STRUCTURE
   ENDIF
   SHOW GET adddbf DISABLE
   SHOW GET moddbf ENABLE
ELSE
   CREATE (m.dbfname)
ENDIF
SHOW GETS
RETURN .T.


*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX00LW7C3           moddbf VALID                       ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         APPSCX,     Record Number:   10    ║
*       ║ Variable:            moddbf                             ║
*       ║ Called By:           VALID Clause                       ║
*       ║ Object Type:         Push Button                        ║
*       ║ Snippet Number:      4                                  ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px00lw7c3     &&  moddbf VALID
#REGION 1
IF !EMPTY(m.dbfname)
   IF !EMPTY(opendbf(m.dbfname))
      MODIFY STRUCTURE
   ELSE
      SHOW GET moddbf DISABLE
      RETURN -2
   ENDIF
ENDIF
RETURN .T.


*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX00LW7S4           Listdbf VALID                      ║
