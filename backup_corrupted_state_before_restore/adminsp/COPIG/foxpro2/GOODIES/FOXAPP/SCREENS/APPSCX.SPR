*       ║                                                         ║
*       ║ From Screen:         APPSCX,     Record Number:   12    ║
*       ║ Variable:            scxname                            ║
*       ║ Called By:           WHEN Clause                        ║
*       ║ Object Type:         Field                              ║
*       ║ Snippet Number:      6                                  ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px00lw890     &&  scxname WHEN
#REGION 1
m.scxname = PADR(m.scxname,m.apppathlen)
SHOW GET modscx DISABLE
SHOW GET addscx DISABLE
SET CURSOR ON
RETURN .T.


*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX00LW8MW           scxname VALID                      ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         APPSCX,     Record Number:   12    ║
*       ║ Variable:            scxname                            ║
