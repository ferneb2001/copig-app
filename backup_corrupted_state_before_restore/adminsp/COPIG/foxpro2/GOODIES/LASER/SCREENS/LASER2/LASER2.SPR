#REGION 2
IF WVISIBLE("_px211r9nt")
	ACTIVATE WINDOW _px211r9nt SAME
ELSE
	ACTIVATE WINDOW _px211r9nt NOSHOW
ENDIF
@ 0,1 GET act3 ;
	PICTURE "@*HN Top;Prior;Next;Bottom;Browse;Quit" ;
	SIZE 1,10,2 ;
	DEFAULT 2 ;
	VALID _px211rcnq()

IF NOT WVISIBLE("_px211r9nt")
	ACTIVATE WINDOW _px211r9nt
