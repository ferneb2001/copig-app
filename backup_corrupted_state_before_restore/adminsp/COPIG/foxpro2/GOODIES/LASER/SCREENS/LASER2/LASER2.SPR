IF USED("laser")
	SELECT laser
	USE
ENDIF

SELECT (m.currarea)


#REGION 0
IF m.talkstat = "ON"
	SET TALK ON
ENDIF
IF m.compstat = "ON"
	SET COMPATIBLE ON
ENDIF


*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║                   LASER2 Cleanup Code                   ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*

#REGION 1
pop menu _msysmenu
if ('VGA'$sys(2006) or 'EGA'$sys(2006)) and saverow < 26
	set display to vga25
endif

*
*	Procedure to setup ltags fields
*
procedure setltags
ltags(1) = "Record#"
for i = 2 to 256
	if len(tag(i-1)) = 0
		i = i - 1
		dimension ltags(i)
		exit
	else
		ltags(i) = tag(i-1)
	endif
endfor
ord = "TITLE"
set order to TITLE
show get ord



*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX211RBF5           ord VALID                          ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         LASER2,     Record Number:   34    ║
*       ║ Variable:            ord                                ║
*       ║ Called By:           VALID Clause                       ║
*       ║ Object Type:         Popup                              ║
*       ║ Snippet Number:      1                                  ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px211rbf5     &&  ord VALID
#REGION 1
if ord = "Record#"
	set order to
else
	set order to (ord)
endif
go top
show gets


*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX211RCNQ           act3 VALID                         ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         CONTROL2,     Record Number:    2  ║
*       ║ Variable:            act3                               ║
*       ║ Called By:           VALID Clause                       ║
*       ║ Object Type:         Push Button                        ║
*       ║ Snippet Number:      2                                  ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px211rcnq     &&  act3 VALID
#REGION 2
do case
case act3 = 1
	go top
case act3 = 2
	skip -1
	if bof()
		go top
	endif
case act3 = 3
	skip 1
	if eof()
		go bottom
	endif
case act3 = 4
	go bottom
case act3 = 5
	do browser.spr
case act3 = 6
	clear read
endcase
show gets
return 0

*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX211RCKE           Read Level Show                    ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         Multiple Screens                   ║
*       ║ Called By:           READ Statement                     ║
*       ║ Snippet Number:      3                                  ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px211rcke     && Read Level Show
PRIVATE currwind
STORE WOUTPUT() TO currwind
*
* Show Code from screen: LASER2
*
#REGION 1
ord = iif(len(order())=0,"Record#",order())

IF SYS(2016) = "_PX211R9K8" OR SYS(2016) = "*"
	ACTIVATE WINDOW _px211r9k8 SAME
	@ 1,65 SAY recno() ;
		SIZE 1,4 ;
		PICTURE "9,999"
	@ 1,51 SAY iif(DELETED(),'Yes','No ') ;
		SIZE 1,4
ENDIF
IF NOT EMPTY(currwind)
	ACTIVATE WINDOW (currwind) SAME
ENDIF