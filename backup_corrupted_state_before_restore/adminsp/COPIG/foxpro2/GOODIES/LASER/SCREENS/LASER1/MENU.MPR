*       ║ Snippet:    8                                           ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
PROCEDURE _px211qpeb
if mrkbar("enviro",bar())
   set status off
   set mark of bar bar() of enviro	to .f.
else
   set status on
   set mark of bar bar() of enviro	to .t.
endif
return



