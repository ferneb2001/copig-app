*       ║                                                         ║
*       ║                   ALERT Screen Layout                   ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*

#REGION 1
IF WVISIBLE("_px90z5rcg")
	ACTIVATE WINDOW _px90z5rcg SAME
ELSE
	ACTIVATE WINDOW _px90z5rcg NOSHOW
ENDIF
@ 2,0 SAY PADC(m.anystring,46) ;
	SIZE 1,48 ;
	PICTURE "@I"

IF NOT WVISIBLE("_px90z5rcg")
	ACTIVATE WINDOW _px90z5rcg
ENDIF


