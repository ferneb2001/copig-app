*
FUNCTION _px911b1pz     &&  gethelp VALID
#REGION 1
HELP ■ Restaurant Manager

*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX911B1UZ           newrecord VALID                    ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         RESTAURS,     Record Number:   40  ║
*       ║ Variable:            newrecord                          ║
*       ║ Called By:           VALID Clause                       ║
*       ║ Object Type:         Push Button                        ║
*       ║ Snippet Number:      12                                 ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px911b1uz     &&  newrecord VALID
#REGION 1
m.savereco = RECNO()

LOCATE FOR DELETED() AND EMPTY(restaurant)
IF NOT FOUND()
	APPEND BLANK
ELSE
	RECALL
ENDIF

m.adding = .T.

REPLACE cuisine WITH cuis[1]
REPLACE rating  WITH rati[1]
REPLACE cost    WITH cst[1]

SHOW GET m.newrecord DISABLE
SHOW GET m.editrecord,1 PROMPT "\<Save" ENABLE
SHOW GET m.setorder DISABLE
SHOW GET m.cancel ENABLE

_CUROBJ = OBJNUM(restaurant)

SHOW GETS LOCK
SHOW GETS DISABLE WINDOW controls

SET SKIP OF POPUP _MRECORD .T.
SET SKIP OF BAR 1 OF reports .T.
SET SKIP OF BAR 9 OF _MSYSTEM .T.

*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX911B224           m.editrecord WHEN                  ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         RESTAURS,     Record Number:   41  ║
*       ║ Variable:            m.editrecord                       ║
*       ║ Called By:           WHEN Clause                        ║
*       ║ Object Type:         Push Button                        ║
*       ║ Snippet Number:      13                                 ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px911b224     &&  m.editrecord WHEN
#REGION 1
IF NOT (m.adding OR m.editing)
	RETURN .T.
ENDIF
IF EMPTY(restaurant)
	?? CHR(7)
	WAIT WINDOW "Enter restaurant name" NOWAIT
	_CUROBJ = OBJNUM(restaurant)
	RETURN .F.
ENDIF

*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX911B26F           m.editrecord VALID                 ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         RESTAURS,     Record Number:   41  ║
*       ║ Variable:            m.editrecord                       ║
*       ║ Called By:           VALID Clause                       ║
*       ║ Object Type:         Push Button                        ║
*       ║ Snippet Number:      14                                 ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px911b26f     &&  m.editrecord VALID
#REGION 1
PRIVATE m.onoff

IF NETWORK()
	IF m.editing = .F. AND m.adding = .F.
			
		SCATTER MEMVAR MEMO

		_CUROBJ = OBJNUM(restaurant)	

		*
		* Attempt to LOCK the current record will be made.
		* If already LOCKED, pressing ESC will force execution
		* of the ON ERROR routine.
		*
		SHOW GETS LOCK
		
		IF m.islocked
			m.islocked = .F.
			RETURN
		ENDIF
		
		SHOW GET m.newrecord DISABLE
		SHOW GET m.editrecord,1 PROMPT "\<Save" ENABLE
		SHOW GET m.cancel ENABLE
		SHOW GET m.setorder DISABLE
		SHOW GETS DISABLE WINDOW controls
		
		m.editing = .T.
		m.onoff = .T.
	ELSE
		m.editing = .F.
		IF m.adding
			WAIT WINDOW "Record has been saved" NOWAIT
			m.adding = .F.
		ELSE
			WAIT WINDOW "Changes have been saved" NOWAIT
		ENDIF
		
		_CUROBJ = OBJNUM(m.choice, 1)
		
		SHOW GET m.newrecord ENABLE
		SHOW GET m.cancel DISABLE
		SHOW GET m.setorder ENABLE
		SHOW GET m.choice, 5 ENABLE
		SHOW GET m.choice, 6 ENABLE
		SHOW GET m.editrecord,1 PROMPT "\<Edit"
		SHOW GETS ENABLE WINDOW controls
		UNLOCK	

		SHOW GETS
		
		m.onoff = .F.	
	ENDIF
ELSE
	*
	* If not running FoxPro/LAN the only time <Save> button can
	* be pressed is if adding a new record.
	*
	m.adding = .F.
		
	WAIT WINDOW "Record has been saved" NOWAIT

	_CUROBJ = OBJNUM(m.choice, 1)
		
	SHOW GET m.newrecord ENABLE
	SHOW GET m.editrecord DISABLE
	SHOW GET m.setorder ENABLE
	SHOW GET m.choice, 5 ENABLE
	SHOW GET m.choice, 6 ENABLE

	SHOW GETS
	m.onoff = .F.	
ENDIF

SET SKIP OF POPUP _MRECORD m.onoff
SET SKIP OF BAR 1 OF reports m.onoff
SET SKIP OF BAR 9 OF _MSYSTEM m.onoff





*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX911B2KV           cancel VALID                       ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         RESTAURS,     Record Number:   42  ║
*       ║ Variable:            cancel                             ║
*       ║ Called By:           VALID Clause                       ║
*       ║ Object Type:         Push Button                        ║
*       ║ Snippet Number:      15                                 ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px911b2kv     &&  cancel VALID
#REGION 1
IF m.editing OR NOT NETWORK()
	GATHER MEMVAR MEMO
ENDIF
IF m.adding
	DELETE
	GOTO RECORD m.savereco
ENDIF

m.adding = .F.
m.popupedit = .F.
m.editing = .F.

IF NETWORK()
	SHOW GET m.editrecord, 1 PROMPT "\<Edit"
	SHOW GET m.cancel DISABLE
ELSE
	SHOW GET m.editrecord DISABLE
ENDIF

UNLOCK

SHOW GET m.newrecord ENABLE
SHOW GET m.setorder ENABLE
SHOW GETS WINDOW controls
SHOW GETS

_CUROBJ = OBJNUM(m.choice, 1)
	
SHOW GET m.choice, 5 ENABLE
SHOW GET m.choice, 6 ENABLE

SET SKIP OF POPUP _MRECORD .F.
SET SKIP OF BAR 1 OF reports .F.
SET SKIP OF BAR 9 OF _MSYSTEM .F.


*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX911B2T8           m.setorder VALID                   ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         RESTAURS,     Record Number:   43  ║
*       ║ Variable:            m.setorder                         ║
*       ║ Called By:           VALID Clause                       ║
*       ║ Object Type:         Popup                              ║
*       ║ Snippet Number:      16                                 ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px911b2t8     &&  m.setorder VALID
#REGION 1
DO CASE
CASE m.setorder = 1
	IF NOT EMPTY(ORDER())
		SET ORDER TO
		GO TOP
	ENDIF
CASE m.setorder = 2
	IF LOWER(ORDER()) <> "restaurant"
		SET ORDER TO TAG restaurant
		GO TOP
	ENDIF
CASE m.setorder = 3
	IF LOWER(ORDER()) <> "cuisine"
		SET ORDER TO TAG cuisine
		GO TOP
	ENDIF
CASE m.setorder = 4
	IF LOWER(ORDER()) <> "rating"
		SET ORDER TO TAG rating
		GO TOP
	ENDIF
CASE m.setorder = 5
	IF LOWER(ORDER()) <> "cost"
		SET ORDER TO TAG cost
		GO TOP
	ENDIF
ENDCASE
SHOW GETS


*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX911B33C           m.choice VALID                     ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         CONTROL2,     Record Number:    2  ║
*       ║ Variable:            m.choice                           ║
*       ║ Called By:           VALID Clause                       ║
*       ║ Object Type:         Push Button                        ║
*       ║ Snippet Number:      17                                 ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px911b33c     &&  m.choice VALID
#REGION 2
DO CASE
CASE m.choice = "Next"
	SKIP 1
	IF EOF() OR RECNO() = m.bottomrec
		GO BOTTOM
		SHOW GET m.choice, 1 DISABLE
		SHOW GET m.choice, 4 DISABLE
	ELSE
		IF RECNO() > m.toprec
			SHOW GET m.choice, 2 ENABLE
			SHOW GET m.choice, 3 ENABLE
		ENDIF
	ENDIF
CASE m.choice = "Prior"
	SKIP -1
	IF BOF() OR RECNO() = m.toprec
		GO TOP
		SHOW GET m.choice, 2 DISABLE
		SHOW GET m.choice, 3 DISABLE
	ELSE
		IF RECNO() < m.bottomrec
			SHOW GET m.choice, 1 ENABLE
			SHOW GET m.choice, 4 ENABLE
		ENDIF
	ENDIF	
CASE m.choice = "Top"
	GO TOP	
	SHOW GET m.choice, 1 ENABLE
	SHOW GET m.choice, 2 DISABLE
	SHOW GET m.choice, 3 DISABLE
	SHOW GET m.choice, 4 ENABLE
CASE m.choice = "Bottom"
	GO BOTTOM
	SHOW GET m.choice, 1 DISABLE
	SHOW GET m.choice, 2 ENABLE
	SHOW GET m.choice, 3 ENABLE
	SHOW GET m.choice, 4 DISABLE
CASE m.choice = "Locate"
	DO browser.spr	
CASE m.choice = "OK"
	m.idlequit = .T.	
	m.quitting = .T.
	CLEAR READ
ENDCASE
SHOW GETS

*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX911B317           Read Level When                    ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         Multiple Screens                   ║
*       ║ Called By:           READ Statement                     ║
*       ║ Snippet Number:      18                                 ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px911b317     && Read Level When
*
* When Code from screen: RESTAURS
*
#REGION 1
SET SKIP OF BAR 2 OF reports .T.
SET SKIP OF BAR 3 OF reports .T.

IF VAL(SYS(1001)) < 223000
	SET SKIP OF BAR 1 OF reports .T.
ENDIF
IF NOT NETWORK()
	SHOW GET m.editrecord,1 PROMPT "\<Save" DISABLE
ENDIF

*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX911B319           Read Level Activate                ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         Multiple Screens                   ║
*       ║ Called By:           READ Statement                     ║
*       ║ Snippet Number:      19                                 ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px911b319     && Read Level Activate
*
* Activate Code from screen: RESTAURS
*
#REGION 1
IF NETWORK() AND NOT (m.editing OR m.adding)
	SHOW GET m.editrecord ENABLE
	SHOW GET m.cancel DISABLE
ENDIF

*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX911B31B           Read Level Deactivate              ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         Multiple Screens                   ║
*       ║ Called By:           READ Statement                     ║
*       ║ Snippet Number:      20                                 ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px911b31b     && Read Level Deactivate
*
* Deactivate Code from screen: RESTAURS
*
#REGION 1
IF m.editing
	?? CHR(7)
	WAIT WINDOW "Please confirm changes" NOWAIT
	RETURN .F.
ENDIF
RETURN NOT WREAD()

*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX911B31D           Read Level Show                    ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         Multiple Screens                   ║
*       ║ Called By:           READ Statement                     ║
*       ║ Snippet Number:      21                                 ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px911b31d     && Read Level Show
PRIVATE currwind
STORE WOUTPUT() TO currwind
*
* Show Code from screen: RESTAURS
*
#REGION 1
IF NOT m.adding AND NOT m.popupedit
	SHOW GET m.newcuis DISABLE
	SHOW GET m.newrating DISABLE
	SHOW GET m.newcost DISABLE
ENDIF
SCATTER MEMVAR MEMO
IF SYS(2016) = "RESTAURS" OR SYS(2016) = "*"
	ACTIVATE WINDOW restaurs SAME
	@ 1,47 SAY IIF(DELETED(),"DELETED","") ;
		SIZE 1,8 ;
		COLOR R+/B*   
ENDIF
*
* Show Code from screen: CONTROL2
*
#REGION 2
IF EOF()
	GO BOTTOM
ENDIF

m.saverecno = RECNO()
GO TOP
m.toprec = RECNO()
GO BOTTOM
m.bottomrec = RECNO()
GO m.saverecno

IF RECNO() = m.bottomrec
	SHOW GET m.choice, 1 DISABLE
	SHOW GET m.choice, 2 ENABLE
	SHOW GET m.choice, 3 ENABLE
	SHOW GET m.choice, 4 DISABLE
ELSE
	IF RECNO() = m.toprec
		SHOW GET m.choice, 1 ENABLE
		SHOW GET m.choice, 2 DISABLE
		SHOW GET m.choice, 3 DISABLE
		SHOW GET m.choice, 4 ENABLE
	ELSE
		SHOW GET m.choice ENABLE
	ENDIF
ENDIF

IF NOT EMPTY(currwind)
	ACTIVATE WINDOW (currwind) SAME
ENDIF