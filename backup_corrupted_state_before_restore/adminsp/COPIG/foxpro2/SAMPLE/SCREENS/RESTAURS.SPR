#REGION 1
IF NETWORK()
	SET EXCLUSIVE OFF			&& Open all databases for shared use.
	SET REPROCESS TO AUTOMATIC	&& Attempt to lock until sucess or ESC.
	SET MULTILOCKS OFF			&& Lock only one record at a time.
	SET REFRESH TO 1			&& Refresh BROWSEs every second.
ENDIF


*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║             CONTROL2 Setup Code - SECTION 1             ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*

#REGION 2
*
* Screen description:
* This screen is a UTILITY screen.  It may be combined with any other
* screens.  All variables used by this screen have been declared REGIONAL to
* encapsulate them (i.e., to avoid conflict with variables from other
* screens).  All variables also have 'm.' prefix to avoid conflict with
* 'unknown' database field names.
*
* Points of interest:
* This screen has been designed to dim its buttons when they
* are not appropritate (i.e., when at TOP dim < Top >, etc.)
* Since TOP and BOTTOM operate within a given scope, if you wish to use this
* screen in presence of any FILTERING (scope altering) conditions make sure
* the control utility screen follows the other screen when you combine them.
*


#REGION 0
REGIONAL m.currarea, m.talkstat, m.compstat

IF SET("TALK") = "ON"
	SET TALK OFF
	m.talkstat = "ON"
ELSE
	m.talkstat = "OFF"
ENDIF
m.compstat = SET("COMPATIBLE")
SET COMPATIBLE FOXPLUS

*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║         S3008076 Databases, Indexes, Relations          ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*

IF USED("restaurs")
	SELECT restaurs
	SET ORDER TO 0
ELSE
	SELECT 0
	USE (LOCFILE("dbfs\restaurs.dbf","DBF","Where is restaurs?"));
		AGAIN ALIAS restaurs ;
		ORDER 0
ENDIF


*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║                    Window definitions                   ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*

IF NOT WEXIST("restaurs")
	DEFINE WINDOW restaurs ;
		FROM 2, 2 ;
		TO 24,62 ;
		TITLE " Restaurant Manager " ;
		FLOAT ;
		NOCLOSE ;
		SHADOW ;
		COLOR SCHEME 1
ENDIF

IF NOT WEXIST("controls")
	DEFINE WINDOW controls ;
		FROM 2, 65 ;
		TO 24,76 ;
		FLOAT ;
		NOCLOSE ;
		SHADOW ;
		COLOR SCHEME 1
ENDIF


*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║             RESTAURS Setup Code - SECTION 2             ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*

#REGION 1
PRIVATE m.adding, m.popupedit, m.setorder, m.editing, ;
	m.savereco, m.islocked
	
m.savereco  = RECNO()
m.adding    = .F.
m.popupedit = .F.
m.setorder  = 1
m.editing   = .F.
m.islocked  = .F.

SET EXCLUSIVE OFF

STORE 0 TO m.cuscnt, m.ratcnt, m.cstcnt
DIMENSION cuis[10], rati[10], cst[10]

m.savrec = RECNO()
GO TOP
SCAN FOR NOT DELETED()
	m.string = ALLTRIM(Cuisine)
	IF NOT EMPTY(m.string) AND ASCAN(cuis, m.string) = 0
		m.cuscnt = m.cuscnt + 1
		IF m.cuscnt > ALEN(cuis)
			DIMENSION cuis[m.cuscnt]
		ENDIF
		cuis[m.cuscnt] = m.string
	ENDIF
	
	m.string = ALLTRIM(Rating)
	IF NOT EMPTY(m.string) AND ASCAN(rati, m.string) = 0
		m.ratcnt = m.ratcnt + 1
		IF m.ratcnt > ALEN(rati)
			DIMENSION rati[m.ratcnt]
		ENDIF
		rati[m.ratcnt] = m.string
	ENDIF
	
	m.string = ALLTRIM(Cost)
	IF NOT EMPTY(m.string) AND ASCAN(cst, m.string) = 0
		m.cstcnt = m.cstcnt + 1
		IF m.cstcnt > ALEN(cst)
			DIMENSION cst[m.cstcnt]
		ENDIF
		cst[m.cstcnt] = m.string
	ENDIF
ENDSCAN

DIMENSION rati[m.ratcnt], cuis[m.cuscnt], cst[m.cstcnt]

= ASORT(cuis)
= ASORT(rati)
= ASORT(cst)

m.ratcnt = m.ratcnt + 1
m.cuscnt = m.cuscnt + 1
m.cstcnt = m.cstcnt + 1

DIMENSION rati[m.ratcnt], cuis[m.cuscnt], cst[m.cstcnt]

rati[m.ratcnt] = "Other..."
cuis[m.cuscnt] = "Other..."
cst [m.cstcnt] = "Other..."

GOTO RECORD m.savrec

SCATTER MEMVAR MEMO BLANK

*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║             CONTROL2 Setup Code - SECTION 2             ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*

#REGION 2
REGIONAL m.choice, m.toprec, m.bottomrec, m.saverecno
PRIVATE m.quitting
m.quitting = .F.
m.choice = "OK"

IF EOF()
	GO BOTTOM
ENDIF

m.saverecno = RECNO()
GO TOP
m.toprec = RECNO()
GO BOTTOM
m.bottomrec = RECNO()
GO m.saverecno



