*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX911B0M0           m.newcuis VALID                    ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         RESTAURS,     Record Number:   25  ║
*       ║ Variable:            m.newcuis                          ║
*       ║ Called By:           VALID Clause                       ║
*       ║ Object Type:         Field                              ║
*       ║ Snippet Number:      4                                  ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px911b0m0     &&  m.newcuis VALID
#REGION 1
IF EMPTY(m.newcuis) OR ASCAN(cuis, m.newcuis)<>0
	RETURN .T.
ENDIF
	
= AINS(cuis,m.cuscnt)
cuis[m.cuscnt] = ALLTRIM(m.newcuis)
= ASORT(cuis)
m.cuscnt = m.cuscnt+1
	
DIMENSION cuis[m.cuscnt]
cuis[m.cuscnt] = "Other..."
	
REPLACE cuisine WITH ALLTRIM(m.newcuis)

m.newcuis = ""
m.popupedit = .F.
SHOW GET m.newcuis DISABLE
SHOW GET cuisine


