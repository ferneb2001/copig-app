	DEFINE WINDOW accnts ;
		FROM 1, 7 ;
		TO 16,56 ;
		TITLE " Account Manager " ;
		FLOAT ;
		NOCLOSE ;
		SHADOW ;
		COLOR SCHEME 1
ENDIF

IF NOT WEXIST("controls")
	DEFINE WINDOW controls ;
