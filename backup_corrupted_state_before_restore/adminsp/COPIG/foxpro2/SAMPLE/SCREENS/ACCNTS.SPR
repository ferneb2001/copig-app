*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px90p0nyn     &&  m.saverecord WHEN
#REGION 1
IF EMPTY(m.acct_id)
	?? CHR(7)
	WAIT WINDOW "You must provide an account number" NOWAIT
	_CUROBJ = OBJNUM(m.acct_id)
	RETURN .F.
ELSE
	IF EMPTY(m.type)
		?? CHR(7)
		WAIT WINDOW "Select account type" NOWAIT
		_CUROBJ = OBJNUM(m.type)
		RETURN .F.
	ENDIF
ENDIF


