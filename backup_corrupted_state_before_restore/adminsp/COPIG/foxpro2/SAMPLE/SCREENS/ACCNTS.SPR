*       ║                                                         ║
*       ║ _PX90P0P6Z           Read Level When                    ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         Multiple Screens                   ║
*       ║ Called By:           READ Statement                     ║
*       ║ Snippet Number:      14                                 ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px90p0p6z     && Read Level When
*
* When Code from screen: ACCNTS
*
#REGION 1
SET SKIP OF BAR 3 OF reports .T.

IF VAL(SYS(1001)) < 223000
	SET SKIP OF BAR 1 OF reports .T.
ENDIF

*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX90P0P72           Read Level Activate                ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         Multiple Screens                   ║
*       ║ Called By:           READ Statement                     ║
*       ║ Snippet Number:      15                                 ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px90p0p72     && Read Level Activate
*
* Activate Code from screen: ACCNTS
*
#REGION 1
IF UPPER(WLAST()) = "DETAILS" OR UPPER(WLAST()) = "DETAILS.SERVICE"
	SELECT credcard
ENDIF

IF NOT WEXIST("Details")
	SELECT details
	BROWSE LAST NOWAIT NORMAL
	SELECT credcard
ENDIF


*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX90P0P76           Read Level Deactivate              ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         Multiple Screens                   ║
*       ║ Called By:           READ Statement                     ║
*       ║ Snippet Number:      16                                 ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px90p0p76     && Read Level Deactivate
*
* Deactivate Code from screen: ACCNTS
*
#REGION 1
IF m.adding OR m.editing
	?? CHR(7)
	WAIT WINDOW "Please confirm changes" NOWAIT
	ACTIVATE WINDOW accnts
ENDIF
IF INLIST(LOWER(WONTOP()), ;
	"details", ;
	"details.service")
	RETURN .F.
ENDIF
RETURN NOT WREAD()

*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX90P0P79           Read Level Show                    ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         Multiple Screens                   ║
*       ║ Called By:           READ Statement                     ║
*       ║ Snippet Number:      17                                 ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px90p0p79     && Read Level Show
PRIVATE currwind
STORE WOUTPUT() TO currwind
*
* Show Code from screen: ACCNTS
*
#REGION 1
IF NOT m.adding
	SCATTER MEMVAR MEMO
	SHOW GET m.type
	IF EOF("details")
		SHOW GET m.balance DISABLE
	ELSE
		SHOW GET m.balance ENABLE
	ENDIF
ENDIF
IF SYS(2016) = "ACCNTS" OR SYS(2016) = "*"
	ACTIVATE WINDOW accnts SAME
	@ 1,36 SAY IIF(DELETED(),"DELETED",SPACE(7)) ;
		SIZE 1,7
ENDIF
*
* Show Code from screen: CONTROL2
*
#REGION 2
IF EOF()
	GO BOTTOM
ENDIF

m.saverecno = RECNO()
GO TOP
m.toprec = RECNO()
GO BOTTOM
m.bottomrec = RECNO()
GO m.saverecno

IF RECNO() = m.bottomrec
	SHOW GET m.choice, 1 DISABLE
	SHOW GET m.choice, 2 ENABLE
	SHOW GET m.choice, 3 ENABLE
	SHOW GET m.choice, 4 DISABLE
ELSE
	IF RECNO() = m.toprec
		SHOW GET m.choice, 1 ENABLE
		SHOW GET m.choice, 2 DISABLE
		SHOW GET m.choice, 3 DISABLE
		SHOW GET m.choice, 4 ENABLE
	ELSE
		SHOW GET m.choice ENABLE
	ENDIF
ENDIF

IF NOT EMPTY(currwind)
	ACTIVATE WINDOW (currwind) SAME
ENDIF