*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX90Z4TVF           qy VALID                           ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         BROWSER,     Record Number:   11   ║
*       ║ Variable:            qy                                 ║
*       ║ Called By:           VALID Clause                       ║
*       ║ Object Type:         Push Button                        ║
*       ║ Snippet Number:      6                                  ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px90z4tvf     &&  qy VALID
#REGION 1
PRIVATE x, i, cnt, stime, etime, y, rno, k, empty
IF qptr = 0
   WAIT WINDOW ALLTRIM(TRANS(RECCOUNT(),"9,999,999"))+" Records" NOWAIT
   ACTIVATE SCREEN
   BROWSE NOMODIFY NOAPPEND
ELSE
   FOR k = 1 TO qptr
      IF QUERY(k) <> "═"
         x = "("+editquery(TRIM(QUERY(k)))
         EXIT
      ENDIF
   ENDFOR
   FOR i = k+1 TO qptr
      IF QUERY(i) = "═"
         IF QUERY(i-1) = "═"
            LOOP
         ENDIF
         x = x + ") OR ("
      ELSE
         IF QUERY(i-1) <> "═"
            x = x + " AND "
         ENDIF
         x = x + editquery(TRIM(QUERY(i)))
      ENDIF
   ENDFOR
   x = x + ")"
   empty = RAT(' OR ()',x)
   IF empty<>0
      x = SUBSTR(x,1,empty-1)
   ENDIF
   rno = RECNO()
   stime = SECONDS()
   IF LEN(x) > 255
      WAIT WINDOW "Expression too long " NOWAIT
      RETURN 0
   ENDIF
   COUNT FOR &x TO cnt
   etime = SECONDS()
   y = ALLTRIM(TRANS(cnt,"9,999,999"))+" Records, "
   y = y + ALLTRIM(TRANS(etime-stime,"999.99")) + " Secs."
   WAIT WINDOW y NOWAIT
   IF cnt = 0
      GO rno
   ELSE
      GO TOP
      ACTIVATE SCREEN
      BROWSE NOMODIFY NOAPPEND FOR &x
   ENDIF
ENDIF
_CUROBJ = 1
SHOW GETS





