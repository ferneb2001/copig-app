#REGION 1
PRIVATE sought, seektype, bact, ;
   flds, fl, qptr, query, op, qp, ;
   tags, tg, i, bact, qy, dbfs, dx, dbc, ;
   fieldname

SET EXACT OFF

DIMENSION flds(256), query(50), tags(256), dbfs(25)

dbc = 0
FOR i = 1 TO 25
   IF LEN(DBF(i)) # 0
      dbc = dbc + 1
      dbfs(dbc) = ALIAS(i)
   ENDIF
ENDFOR

IF dbc = 0
   X = GETFILE("DBF","Pick database to BROWSE")
   IF LEN(X) = 0
      WAIT WINDOW "Cancelled" NOWAIT
      RETURN
   ELSE
      USE (X)
      dbc = 1
      dbfs(1) = ALIAS()
   ENDIF
ELSE
   IF LEN(FIELD(1)) = 0
      SELECT (dbfs(1))
   ENDIF
ENDIF
DIMENSION dbfs(dbc)
dx = ALIAS()
fieldname = ""
tg = ""
DO settags

query = " "
qptr = 0
qp = 1
sought = ""
op = "="
DO fset


