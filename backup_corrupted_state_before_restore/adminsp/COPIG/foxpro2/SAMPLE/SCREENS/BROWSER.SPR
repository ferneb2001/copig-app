*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX90Z4THW           bact VALID                         ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         BROWSER,     Record Number:    9   ║
*       ║ Variable:            bact                               ║
*       ║ Called By:           VALID Clause                       ║
*       ║ Object Type:         Push Button                        ║
*       ║ Snippet Number:      4                                  ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px90z4thw     &&  bact VALID
#REGION 1
PRIVATE x, i
DO CASE
CASE bact = 1
   = ADEL(query,qp)
   query(50) = " "
   qptr = qptr - 1
   qp = MIN(qp,qptr+1)
   DO qset
CASE bact = 2
   IF qp > 1 AND qp <= qptr
      x = query(qp-1)
      query(qp-1) = query(qp)
      query(qp) = x
      qp = qp - 1
   ENDIF
CASE bact = 3
   IF qp <  qptr
      x = query(qp+1)
      query(qp+1) = query(qp)
      query(qp) = x
      qp = qp + 1
   ENDIF
CASE bact = 4
   IF qp < qptr
      FOR i = qptr TO qp+1 STEP -1
         query(i+1) = query(i)
      ENDFOR
      query(qp + 1) = REPLICATE("═",40)
      qp = qp + 2
   ELSE
      query(qptr+1) = REPLICATE("═",40)
      qp = qptr + 2
   ENDIF
   qptr = qptr + 1
ENDCASE
DO setaction
SHOW GET qp


