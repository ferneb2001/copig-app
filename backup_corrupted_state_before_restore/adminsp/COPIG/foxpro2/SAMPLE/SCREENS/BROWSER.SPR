	SIZE 3,6 ;
	DEFAULT "=" ;
	COLOR SCHEME 5, 6
@ 14,24 EDIT sought ;
	PICTURE "@K" ;
	SIZE 1,22,238 ;
	DEFAULT " " ;
	VALID _px90z4so6()
@ 14,48 GET ad ;
	PICTURE "@*VN Add" ;
	SIZE 1,8,1 ;
	DEFAULT 1 ;
	VALID _px90z4ssg()
@ 3,1 GET qp ;
