*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px90z4so6     &&  sought VALID
#REGION 1
IF "'"$sought
   WAIT WINDOW "Can't have single quote in value" NOWAIT
   RETURN 0
ENDIF



*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX90Z4SSG           ad VALID                           ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         BROWSER,     Record Number:    7   ║
*       ║ Variable:            ad                                 ║
*       ║ Called By:           VALID Clause                       ║
*       ║ Object Type:         Push Button                        ║
*       ║ Snippet Number:      2                                  ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px90z4ssg     &&  ad VALID
#REGION 1
PRIVATE x, y, z
IF qptr = 50
   ?? CHR(7)
   WAIT WINDOW "query list is full" NOWAIT
   RETURN 0
ENDIF
x = notag(TRIM(fieldname))
y = ALLTRIM(sought)
typ = TYPE("&x")
IF EMPTY(y) AND NOT typ = "L"
   ?? CHR(7)
   WAIT WINDOW "Missing value" NOWAIT
   RETURN 0
ENDIF
DO CASE
CASE typ = "C"
   y = brackets(y,"'","'")
CASE typ = "D"
   y = brackets(y,"{","}")
CASE typ = "N"
   IF AT('"',y)<>0
   	  WAIT WINDOW "Numeric field; Quotes are not allowed" NOWAIT
   	  RETURN 0
   ENDIF
   typ2 = TYPE("&y")
   IF typ2 <> "N"
      WAIT WINDOW "Numeric field; A number is expected" NOWAIT
      RETURN 0
   ENDIF
ENDCASE
IF typ = "L"
   z = x
ELSE
   z = x + " " + op + " " + y
ENDIF
IF 0 < qp AND qp <= qptr
   query(qp) = z
ELSE
   qptr = qptr + 1
   query(qptr) = z
ENDIF
qp = qptr+1

SHOW GET qp ENABLE
DO setaction
_CUROBJ = 1

*!*****************************************************************
*!
*!      Procedure: BRACKETS
*!
*!*****************************************************************
FUNCTION brackets
PARAMETER x, b1, b2
PRIVATE out, i, v
IF op <> "IN"
   RETURN b1 + x + b2
ENDIF
out = ""
DO WHILE LEN(x) > 0
   i = AT(",", x)
   IF i = 0
      v = x
      x = ""
   ELSE
      v = SUBSTR(x,1,i-1)
      x = IIF(i=LEN(x),"",SUBSTR(x,i+1))
   ENDIF
   IF LEN(out) > 0
      out = out + ","
   ENDIF
   out = out + b1 + v + b2
ENDDO
RETURN out


