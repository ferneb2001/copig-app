	FROM query ;
	SIZE 8,56 ;
	DEFAULT 1 ;
	VALID _px90z4taf() ;
	DISABLE ;
	COLOR SCHEME 6
@ 11,4 GET bact ;
	PICTURE "@*HN Delete;;;Group" ;
	SIZE 1,9,4 ;
	DEFAULT 1 ;
	VALID _px90z4thw() ;
	DISABLE
@ 0,45 GET tg ;
