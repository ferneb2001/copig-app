FUNCTION _px90s7obr     &&  m.cancel VALID
#REGION 1
SCATTER MEMVAR MEMO

m.adding  = .F.
m.editing = .F.
SHOW GET m.newrecord ENABLE
SHOW GET m.saverecord DISABLE
SHOW GET m.cancel DISABLE
SHOW GET m.balance ENABLE

SHOW GET m.choice, 5 ENABLE
SHOW GET m.choice, 6 ENABLE
	
_CUROBJ = OBJNUM(m.choice)
SHOW GETS

SET SKIP OF POPUP _MRECORD .F.
SET SKIP OF POPUP reports .F.
SET SKIP OF BAR 9 OF _MSYSTEM .F.

*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX90S7OHM           m.balance VALID                    ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         CLIENTS,     Record Number:   42   ║
*       ║ Variable:            m.balance                          ║
*       ║ Called By:           VALID Clause                       ║
*       ║ Object Type:         Push Button                        ║
*       ║ Snippet Number:      18                                 ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px90s7ohm     &&  m.balance VALID
#REGION 1
PRIVATE m.saverec1, m.saverec2, m.credits, ;
	m.debits, m.month, m.date, m.day, m.scope

m.month = MONTH(DATE())
m.scope = 1
DO balance.spr WITH m.month, m.scope
IF m.month = 0
	RETURN
ENDIF

m.day = DAY(GOMONTH(CTOD(STR(m.month,2)+"/01/"+STR(YEAR(DATE()),4)),1)-1)
m.date = CTOD(STR(m.month)+"/"+STR(m.day)+"/"+STR(YEAR(DATE())))
SET ESCAPE OFF

IF m.scope = 1
	IF EOF("Details")
		WAIT WINDOW "No records found" NOWAIT
		RETURN
	ENDIF
	DO balanceone
ELSE
	DO balanceall
ENDIF
SET ESCAPE ON
SET TALK NOWINDOW
IF m.scope <> 1
	WAIT WINDOW "All records balanced" NOWAIT
ENDIF

*
* SETTALKWIN - Setup TALK WINDOW.
*
PROCEDURE settalkwin

DEFINE WINDOW talkwindow ;
	FROM 1,48 TO 3,76 ;
	NOFLOAT NOCLOSE SHADOW ;
	COLOR SCHEME 5
ACTIVATE WINDOW talkwindow
	
SET NOTIFY ON
SET TALK WINDOW talkwindow
SET TALK ON

*
* SUMTHEM - Find sum of credits and sum of debits.
*
PROCEDURE sumthem

SUM FOR (details.client_id = clients.client_id AND ;
	details.trans_date<=m.date AND ;
	details.trans_date>clients.baldate AND ;
	ALLTRIM(details.trans_type) = "Payment");
	TO m.credits
	
GO TOP
SUM FOR (details.client_id = clients.client_id AND ;
	details.trans_date<=m.date AND ;
	details.trans_date>clients.baldate AND ;
	(ALLTRIM(details.trans_type) = "Billing" OR ;
	ALLTRIM(details.trans_type) = "Expense"));
	TO m.debits

*
* BALANCEONE - Balance current client account.
*
PROCEDURE balanceone

IF m.baldate >= m.date
	WAIT WINDOW "Account balanced as of "+DTOC(m.baldate) NOWAIT
	RETURN
ENDIF

m.credits = 0.0
m.debits  = 0.0
m.saverec2 = RECNO()
SELECT details
m.saverec1 = RECNO()
GO TOP

DO settalkwin
DO sumthem
	
RELEASE WINDOW talkwindow
SET TALK OFF
WAIT WINDOW STR(m.debits-m.credits,10,2) TIMEOUT 1	
m.startbal = m.startbal - m.credits + m.debits
m.baldate  = m.date

GOTO RECORD m.saverec1
SELECT clients
GOTO RECORD m.saverec2

= showsave()
SHOW GET m.startbal

*
* BALANCEALL - Balance accounts for all clients.
*
PROCEDURE balanceall
PRIVATE m.saverec, m.firstfound

m.saverec = RECNO()
m.firstfound = .T.
GO TOP

SCAN
	m.credits = 0
	m.debits = 0
	
	IF clients.baldate < m.date
		IF m.firstfound
			DO settalkwin
			m.firstfound = .F.
		ENDIF
		
		SELECT details
		GO TOP
		SET TALK ON
	
		DO sumthem
	
		SET TALK OFF
		SELECT clients
		
		REPLACE clients.startbal WITH ;
			clients.startbal - m.credits + m.debits
		REPLACE clients.baldate WITH m.date
	ENDIF
ENDSCAN

SELECT clients
GOTO RECORD m.saverec
RELEASE WINDOW talkwindow
SET TALK OFF
SHOW GETS


*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX90S7P8X           m.choice VALID                     ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         CONTROL1,     Record Number:    2  ║
*       ║ Variable:            m.choice                           ║
*       ║ Called By:           VALID Clause                       ║
*       ║ Object Type:         Push Button                        ║
*       ║ Snippet Number:      19                                 ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px90s7p8x     &&  m.choice VALID
#REGION 2
DO CASE
CASE m.choice = "Next"
	SKIP 1
	IF RECNO() = m.bottomrec
		SHOW GET m.choice, 1 DISABLE
		SHOW GET m.choice, 4 DISABLE
	ELSE
		IF RECNO() > m.toprec
			SHOW GET m.choice, 2 ENABLE
			SHOW GET m.choice, 3 ENABLE
		ENDIF
	ENDIF
CASE m.choice = "Prior"
	SKIP -1
	IF RECNO() = m.toprec
		SHOW GET m.choice, 2 DISABLE
		SHOW GET m.choice, 3 DISABLE
	ELSE
		IF RECNO() < m.bottomrec
			SHOW GET m.choice, 1 ENABLE
			SHOW GET m.choice, 4 ENABLE
		ENDIF
	ENDIF	
CASE m.choice = "Top"
	GO TOP	
	SHOW GET m.choice, 1 ENABLE
	SHOW GET m.choice, 2 DISABLE
	SHOW GET m.choice, 3 DISABLE
	SHOW GET m.choice, 4 ENABLE
CASE m.choice = "Bottom"
	GO BOTTOM
	SHOW GET m.choice, 1 DISABLE
	SHOW GET m.choice, 2 ENABLE
	SHOW GET m.choice, 3 ENABLE
	SHOW GET m.choice, 4 DISABLE
CASE m.choice = "Locate"
	*
	* Browser is another utility screen
	*
	DO browser.spr	
CASE m.choice = "OK"
	m.idlequit = .T.
	m.quitting = .T.	
	CLEAR READ
ENDCASE
SHOW GETS

