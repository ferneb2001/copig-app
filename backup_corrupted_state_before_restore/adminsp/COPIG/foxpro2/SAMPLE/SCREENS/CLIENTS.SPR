*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║ _PX90S7MJX           m.state WHEN                       ║
*       ║                                                         ║
*       ║ Function Origin:                                        ║
*       ║                                                         ║
*       ║ From Screen:         CLIENTS,     Record Number:   30   ║
*       ║ Variable:            m.state                            ║
*       ║ Called By:           WHEN Clause                        ║
*       ║ Object Type:         Field                              ║
*       ║ Snippet Number:      5                                  ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*
FUNCTION _px90s7mjx     &&  m.state WHEN
#REGION 1
PRIVATE staflds, m.choice, m.savearea, m.count, m.lastkey

m.lastkey = LASTKEY()
m.savearea = SELECT()

IF NOT locatedb("states",0)
	RETURN
ENDIF
	
COUNT TO m.count
DIMENSION staflds[m.count,2]
COPY TO ARRAY staflds
	
= ASORT(staflds,2)

DEFI WIND list FROM 7,34 TO 12,54 NONE
ACTI WIND list

IF NOT EMPTY(m.state)
	m.choice = ASUBSCRIPT(staflds,ASCAN(staflds,m.state,1),1)
ENDIF
@ 0,0 GET m.choice ;
	FROM staflds ;
	PICTURE '@&T' ;
	RANGE 2 ;
	SIZE 6,20 ;
	DEFAULT 1 ;
	VALID statvalid() ;
	COLOR SCHEME 1

READ
RELE WIND list

IF m.state <> clients.state
	= showsave()
ENDIF
USE
SELECT (m.savearea)
IF m.lastkey=5 OR m.lastkey=19 OR m.lastkey=15
	*
	* Provide a way to move between the objects with the keyboard.
	*
	_CUROBJ = OBJNUM(m.city)
ELSE
	_CUROBJ = OBJNUM(m.zip)
ENDIF

FUNCTION statvalid
m.state = staflds[m.choice,1]
SHOW GET m.state LEVEL RDLEVEL()-1


