*       ║                        Setup Code                       ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*

RELEASE PAD _MSYSTEM OF _MSYSMENU

SET TALK OFF

progpath = SYS(16)
npath = SUBSTR(progpath,1,RAT('\',progpath)-1)

conv = '"' + npath + "\convert.app" + '"'
rest = '"' + npath + "\restaurs.app" + '"'
clie = '"' + npath + "\clients.app" + '"'
fami = '"' + npath + "\family.app" + '"'
cred = '"' + npath + "\credit.app" + '"'
cred = '"' + npath + "\credit.app" + '"'
accn = '"' + npath + "\accnts.app" + '"'
tran = '"' + npath + "\trans.app" + '"'

opath = SET("PATH")
IF AT(npath,opath)=0
	opath =	npath+ ;
			";"+npath+"\DBFS" + ;
			";"+npath+"\REPORTS" + ;
			IIF(EMPTY(opath),"",";") + opath
	SET PATH TO &opath
ENDIF


*       ╓─────────────────────────────────────────────────────────╖
*       ║                                                         ║
*       ║                      Menu Definition                    ║
*       ║                                                         ║
*       ╙─────────────────────────────────────────────────────────╜
*

SET SYSMENU AUTOMATIC

DEFINE PAD _px90p88fu OF _MSYSMENU PROMPT "\<System" COLOR SCHEME 3 ;
	BEFORE _MFILE ;
	KEY ALT+S, ""
ON PAD _px90p88fu OF _MSYSMENU ACTIVATE POPUP _msystem

DEFINE POPUP _msystem MARGIN RELATIVE SHADOW COLOR SCHEME 4
DEFINE BAR _MST_ABOUT OF _msystem PROMPT "\<About FoxPro..."
DEFINE BAR _MST_HELP OF _msystem PROMPT "\<Help..." ;
	KEY F1, "F1"
DEFINE BAR _MST_MACRO OF _msystem PROMPT "\<Macros..."
DEFINE BAR _MST_SP100 OF _msystem PROMPT "\-"
DEFINE BAR _MST_FILER OF _msystem PROMPT "\<Filer"
DEFINE BAR _MST_CALCU OF _msystem PROMPT "\<Calculator"
DEFINE BAR _MST_DIARY OF _msystem PROMPT "Calendar/\<Diary"
DEFINE BAR _MST_SPECL OF _msystem PROMPT "\<Special Characters"
DEFINE BAR _MST_ASCII OF _msystem PROMPT "ASC\<II Chart"
DEFINE BAR _MST_CAPTR OF _msystem PROMPT "Ca\<pture"
DEFINE BAR _MST_PUZZL OF _msystem PROMPT "Pu\<zzle"
DEFINE BAR 12 OF _msystem PROMPT "Co\<nversions" ;
	KEY ALT+N, ""
DEFINE BAR 13 OF _msystem PROMPT "\-"
DEFINE BAR 14 OF _msystem PROMPT "\<Organize..." ;
	KEY ALT+O, ""
ON SELECTION BAR 12 OF _msystem DO LOCFILE(&conv,"APP","Where is CONVERT.APP?")
ON BAR 14 OF _msystem ACTIVATE POPUP organizer

DEFINE POPUP organizer MARGIN RELATIVE SHADOW COLOR SCHEME 4
DEFINE BAR 1 OF organizer PROMPT "\<Restaurants" ;
	KEY ALT+R, ""
DEFINE BAR 2 OF organizer PROMPT "C\<lient Manager" ;
	KEY ALT+L, ""
DEFINE BAR 3 OF organizer PROMPT "\<Money Manager" ;
	KEY ALT+M, ""
DEFINE BAR 4 OF organizer PROMPT "\<Family & Friends" ;
	KEY ALT+F, ""
ON SELECTION BAR 1 OF organizer DO LOCFILE(&rest,"APP","Where is RESTAURS.APP?")
ON SELECTION BAR 2 OF organizer DO LOCFILE(&clie,"APP","Where is CLIENT.APP?")
ON BAR 3 OF organizer ACTIVATE POPUP moneymanag
ON SELECTION BAR 4 OF organizer DO LOCFILE(&fami,"APP","Where is FAMILY.APP?")

DEFINE POPUP moneymanag MARGIN RELATIVE SHADOW COLOR SCHEME 4
DEFINE BAR 1 OF moneymanag PROMPT "\<Credit Cards" ;
	KEY ALT+C, ""
DEFINE BAR 2 OF moneymanag PROMPT "\<Accounts" ;
	KEY ALT+A, ""
DEFINE BAR 3 OF moneymanag PROMPT "\-"
DEFINE BAR 4 OF moneymanag PROMPT "\<Transactions" ;
	KEY ALT+T, ""
ON SELECTION BAR 1 OF moneymanag DO LOCFILE(&cred,"APP","Where is CREDIT.APP?")
ON SELECTION BAR 2 OF moneymanag DO LOCFILE(&accn,"APP","Where is ACCNTS.APP?")
ON SELECTION BAR 4 OF moneymanag DO LOCFILE(&tran,"APP","Where is TRANS.APP?")
