PROCEDURE _px9101tcp
IF MRKBAR("environmen",BAR())
	SET CLOCK OFF
	SET MARK OF BAR BAR() OF environmen TO .F.
ELSE
	SET CLOCK ON
	SET MARK OF BAR BAR() OF environmen TO .T.
ENDIF



