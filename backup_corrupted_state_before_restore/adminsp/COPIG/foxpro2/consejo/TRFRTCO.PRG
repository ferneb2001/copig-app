* TRANSFIERE DATOS DE SPRTCOS A SPRTCO
PROCEDURE TRFRTCO
SET TALK OFF
@ 2, 10 SAY 'TRANFIERE REGISTROS DE REP.TCOS'
SELECT 1
USE SPRTCOS
SELECT 2
USE SPRTCO
WSIGUE = 'S'
WMATRI=SPACE(5)
DO WHILE WSIGUE = 'S'
   SELECT 1
   GO TOP
   DO WHILE .NOT. EOF()
      WMATRI= STR(MATPROF,5)
      IF WMATRI <> "00000"
         SELECT 2
         APPEND BLANK
         REPLACE EMPRESA WITH A.EMPRESA
         REPLACE MATPROF WITH A.MATPROF
         REPLACE CATEGOR WITH A.CATEGOR
         REPLACE RTINICIO WITH A.RTINICIO
         REPLACE RTFINAL  WITH A.RTFINAL
         REPLACE RTVINCULO WITH A.RTVINCULO
      ENDIF
      SELECT 1
      SKIP   
   ENDDO
   WSIGUE = 'N'   
ENDDO
CLOSE ALL